PORT=3025
DB_STORAGE=database/reminder_bot.sqlite
# DATABASE_URL=postgres://user:password@localhost:5432/reminder_bot
WEB_API_KEY=dev-key-change-in-production
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
SESSION_SECRET=change-this-session-secret
SENT_HISTORY_RETENTION_MONTHS=3
SENT_HISTORY_CLEANUP_SCHEDULE=15 0 * * *

# MikroTik API untuk registrasi pelanggan hotspot
IP_MIKROTIK=
USER_MIKROTIK=
PASSWORD_MIKROTIK=
PORT_MIKROTIK=8728
PORT_MIKROTIK_FTP=21

# Optional backup router
IP_MIKROTIK_BACKUP=
PORT_MIKROTIK_BACKUP=8728
PORT_MIKROTIK_BACKUP_FTP=21

# Optional browser overrides for whatsapp-web.js
# PUPPETEER_EXECUTABLE_PATH=
# CHROME_PATH=
# CHROMIUM_PATH=

# Fonnte WhatsApp transport untuk reminder/notifikasi pelanggan
FONNTE_ENABLED=true
FONNTE_BACKUP_ENABLED=false
FONNTE_TOKEN=
FONNTE_API_URL=https://api.fonnte.com/send

# Telegram transport untuk file backup MikroTik
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_API_URL=https://api.telegram.org
