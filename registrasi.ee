    ['A', 'B', 'C', 'D'].forEach(col => {
      worksheet.getCell(`${col}${row}`).border = cellStyle.border;
      worksheet.getCell(`${col}${row}`).alignment = cellStyle.alignment;
    });
    row++;
  });
  worksheet.getColumn('A').width = 8;
  worksheet.getColumn('B').width = 25;
  worksheet.getColumn('C').width = 20;
  worksheet.getColumn('D').width = 15;
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  const filename = `generate_${profileName}_${timestamp}.xlsx`;
  const filepath = path.join(EXCEL_FOLDER, filename);
  await workbook.xlsx.writeFile(filepath);
  return filepath;
};

const parseExpiredDateFromComment = (comment) => {
  if (!comment) return null;
  return parseTanggalKomentar(comment);
};

const startAutoRekapInterval = (chatId, intervalMenit) => {
  if (state.autoRekapInterval) {
    clearInterval(state.autoRekapInterval);
  }

  state.autoRekapInterval = setInterval(async () => {
    if (!state.isReady) return;
    if (!chatId) {
      console.warn('[AutoRekap] ADMIN_NUMBER belum disetel, auto rekap dilewati.');
      return;
    }

    console.log(`[AutoRekap] Menjalankan auto rekap...`);
    try {
      await mikrotikOperations.getRekapPendapatan(chatId, { mode: 'bulanan', isAutoCheck: true });
    } catch (error) {
      console.error('[AutoRekap] Gagal menjalankan auto rekap:', error);
    }
  }, intervalMenit * 60 * 1000);
};

const processInBatches = async (items, concurrency, worker) => {
  if (!Array.isArray(items) || items.length === 0) return;
  const chunkSize = Math.max(1, concurrency);
  for (let i = 0; i < items.length; i += chunkSize) {
    const batch = items.slice(i, i + chunkSize);
    await Promise.all(batch.map(worker));
  }
};

const normalizeUserKey = (value) => String(value || '').trim().toLowerCase();

const buildMikrotikUserLookups = (users = []) => {
  const userByName = new Map();
  const userByEmail = new Map();

  (users || []).forEach((user) => {
    const normalizedName = normalizeUserKey(user?.name);
    if (normalizedName) {
      userByName.set(normalizedName, user);
    }

    const emailValue = String(user?.email || '').trim();
    const atIndex = emailValue.indexOf('@');
    if (atIndex > 0) {
      const nomor = emailValue.substring(0, atIndex);
      if (nomor) {
        userByEmail.set(nomor, user);
      }
    }
  });

  return { userByName, userByEmail };
};

const getRouterRowId = (row) => {
  if (!row || typeof row !== 'object') return null;
  const candidates = ['.id', 'id', 'numbers', 'number', '_id'];
  for (const key of candidates) {
    const value = row[key];
    if (value !== undefined && value !== null && String(value).trim() !== '') {
      return String(value).trim();
    }
  }
  return null;
};

const removeHotspotUsersByName = async (conn, username, maxPasses = 3) => {
  const targetKey = normalizeUserKey(username);
  if (!targetKey) return { removed: 0, remaining: 0 };

  let totalRemoved = 0;
  let remaining = 0;

  for (let pass = 1; pass <= maxPasses; pass++) {
    const usersNow = await conn.menu("/ip/hotspot/user").print();
    const matches = (usersNow || []).filter((u) => normalizeUserKey(u.name) === targetKey);
    if (matches.length === 0) {
      remaining = 0;
      break;
    }

    for (const row of matches) {
      const rowId = getRouterRowId(row);
      if (rowId) {
        await conn.menu("/ip/hotspot/user").remove(rowId);
        totalRemoved++;
        continue;
      }
      await conn.menu("/ip/hotspot/user").where('name', row?.name || username).remove();
      totalRemoved++;
    }

    await new Promise((resolve) => setTimeout(resolve, 300));
    const verifyUsers = await conn.menu("/ip/hotspot/user").print();
    remaining = (verifyUsers || []).filter((u) => normalizeUserKey(u.name) === targetKey).length;
    if (remaining === 0) break;
  }

  return { removed: totalRemoved, remaining };
};

// ==================== NOTIFIKASI & BROADCAST ====================
const kirimNotifikasiExpiredJam8Pagi = async () => {
  if (!state.isReady) {
    console.log('[Notifikasi] WhatsApp client belum siap, lewati...');
    return;
  }
  try {
    const pelangganList = bacaPelanggan();
    const historyUsers = bacaHistoryUser();
    if (pelangganList.length === 0 || historyUsers.length === 0) {
      console.log('[Notifikasi] Tidak ada data pelanggan atau history');
      return;
    }
    const now = new Date();
    const todayString = formatDateKeyInTimezone(now);
    const jamDikirim = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    const historyByName = buildLatestHistoryMapByName(
      historyUsers.filter((user) => user?.tanggalExpired),
      true
    );
    const pendingNotifications = [];

    pelangganList.forEach((pelanggan) => {
      const userHistory = historyByName.get(String(pelanggan.username || "").toLowerCase());
      if (!userHistory) return;

      const tanggalExpired = new Date(userHistory.tanggalExpired);
      const selisihJam = (tanggalExpired - now) / (1000 * 60 * 60);
      if (selisihJam <= 0 || selisihJam > 24) return;

      const tanggalExpiredString = formatDateKeyInTimezone(tanggalExpired);
      if (!tanggalExpiredString) return;
      const notifikasiTerakhir = pelanggan.notifikasiHistory?.find((nh) => nh.tanggalExpired === tanggalExpiredString);
      if (notifikasiTerakhir?.dikirim) return;

      const message = `Yth. Bapak/Ibu *${pelanggan.nama}*,\n\nPerkenankan kami menyampaikan pesan otomatis ini sebagai *Peningat Reaktivasi Akun* terkait status akun hotspot Anda.\n\n*Mohon diperhatikan:* Pesan ini *bukan* merupakan notifikasi jatuh tempo pembayaran, melainkan informasi status akun Anda\n\nDetail Akun Hotspot:\n*Username:* ${pelanggan.username}\n*Password:* ${pelanggan.password}\n\nTerimakasih atas perhatian Anda.`;
      pendingNotifications.push({ pelanggan, message, tanggalExpiredString });
    });

    console.log(`[Notifikasi] Menjalankan notifikasi jam 8 pagi: ${now.toLocaleString('id-ID')} | target=${pendingNotifications.length}`);
    let notifikasiDikirim = 0, dataDiperbarui = false;

    await processInBatches(pendingNotifications, BULK_SEND_CONCURRENCY, async ({ pelanggan, message, tanggalExpiredString }) => {
      try {
        await client.sendMessage(`${pelanggan.nomer}@c.us`, message);
        if (!pelanggan.notifikasiHistory) pelanggan.notifikasiHistory = [];
        pelanggan.notifikasiHistory = pelanggan.notifikasiHistory.filter((nh) => nh.tanggalExpired !== tanggalExpiredString);
        pelanggan.notifikasiHistory.push({
          tanggalExpired: tanggalExpiredString,
          dikirim: true,
          tanggalDikirim: todayString,
          jamDikirim
        });
        dataDiperbarui = true;
        notifikasiDikirim++;
        await new Promise((resolve) => setTimeout(resolve, BULK_SEND_DELAY_MS));
      } catch (error) {
        console.error(`Gagal mengirim ke ${pelanggan.nomer}:`, error);
      }
    });
    if (dataDiperbarui) simpanPelanggan(pelangganList);
    console.log(`Notifikasi jam 8 pagi: ${notifikasiDikirim} dikirim`);
  } catch (error) {
    console.error('Error dalam kirimNotifikasiExpiredJam8Pagi:', error);
  }
};

const kirimResetAkunSebelumExpiredJam3Pagi = async () => {
  try {
    const pelangganList = bacaPelanggan();
    const historyUsers = bacaHistoryUser();
    if (pelangganList.length === 0 || historyUsers.length === 0) {
      console.log('[ResetAkun] Tidak ada data pelanggan atau history');
      return;
    }

    const now = new Date();
    const todayString = formatDateKeyInTimezone(now);
    const jamProses = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    const historyByName = buildLatestHistoryMapByName(
      historyUsers.filter((user) => user?.tanggalExpired),
      true
    );

    const pendingReset = [];
    pelangganList.forEach((pelanggan) => {
      if (!pelanggan?.username || !pelanggan?.password || !pelanggan?.profile) return;
      const userHistory = historyByName.get(String(pelanggan.username).toLowerCase());
      if (!userHistory) return;

      const tanggalExpired = new Date(userHistory.tanggalExpired);
      const selisihJam = (tanggalExpired - now) / (1000 * 60 * 60);
      if (selisihJam <= 0 || selisihJam > 24) return;

      const tanggalExpiredString = formatDateKeyInTimezone(tanggalExpired);
      if (!tanggalExpiredString) return;
      const resetTerakhir = pelanggan.resetAkunHistory?.find((rh) => rh.tanggalExpired === tanggalExpiredString);
      if (resetTerakhir?.dijalankan) return;

      pendingReset.push({
        pelanggan,
        username: pelanggan.username,
        password: pelanggan.password,
        profile: pelanggan.profile,
        tanggalExpiredString
      });
    });

    if (pendingReset.length === 0) {
      console.log(`[ResetAkun] Tidak ada akun target pada ${now.toLocaleString('id-ID')}`);
      return;
    }

    console.log(`[ResetAkun] Menjalankan reset akun jam 1 pagi | target=${pendingReset.length}`);
    await executeWithMikrotik(async (conn) => {
      const activeUsers = await conn.menu("/ip/hotspot/active").print();
      const activeByUser = new Map();
      (activeUsers || []).forEach((active) => {
        const key = String(active.user || '').toLowerCase();
        if (!key) return;
        if (!activeByUser.has(key)) activeByUser.set(key, []);
        activeByUser.get(key).push(active);
      });

      let resetSukses = 0;
      let dataDiperbarui = false;

      for (const target of pendingReset) {
        const key = normalizeUserKey(target.username);
        const activeRows = activeByUser.get(key) || [];
        try {
          for (const activeRow of activeRows) {
            if (activeRow?.['.id']) {
              await conn.menu("/ip/hotspot/active").remove(activeRow['.id']);
            }
          }
          const cleanupResult = await removeHotspotUsersByName(conn, target.username);
          if (cleanupResult.remaining > 0) {
            // Fallback: jika user tidak bisa dihapus tuntas, update akun existing agar reset tetap berlaku.
            const usersAfterCleanup = await conn.menu("/ip/hotspot/user").print();
            const existingRows = (usersAfterCleanup || []).filter((u) => normalizeUserKey(u.name) === key);
            if (existingRows.length === 0) {
              throw new Error(`cleanup gagal, masih ada ${cleanupResult.remaining} user bernama ${target.username}`);
            }

            const primaryRow = existingRows[0];
            const primaryId = getRouterRowId(primaryRow);
            if (primaryId) {
              await conn.menu("/ip/hotspot/user").set({
                '.id': primaryId,
                name: target.username,
                password: target.password,
                profile: target.profile
              });
            } else {
              await conn.menu("/ip/hotspot/user").where('name', target.username).update({
                password: target.password,
                profile: target.profile
              });
            }

            for (let i = 1; i < existingRows.length; i++) {
              const extraId = getRouterRowId(existingRows[i]);
              try {
                if (extraId) {
                  await conn.menu("/ip/hotspot/user").remove(extraId);
                } else {
                  await conn.menu("/ip/hotspot/user").where('name', target.username).remove();
                }
              } catch {}
            }

            if (!target.pelanggan.resetAkunHistory) target.pelanggan.resetAkunHistory = [];
            target.pelanggan.resetAkunHistory = target.pelanggan.resetAkunHistory
              .filter((rh) => rh.tanggalExpired !== target.tanggalExpiredString);
            target.pelanggan.resetAkunHistory.push({
              tanggalExpired: target.tanggalExpiredString,
              dijalankan: true,
              tanggalDijalankan: todayString,
              jamDijalankan: jamProses
            });
            target.pelanggan.tanggalUpdate = new Date().toISOString();

            dataDiperbarui = true;
            resetSukses++;
            console.log(`[ResetAkun] Cleanup belum bersih, fallback update user existing: ${target.username}`);
            continue;
          }

          let addSucceeded = false;
          let lastAddError = null;
          for (let addAttempt = 1; addAttempt <= 2; addAttempt++) {
            try {
              await conn.menu("/ip/hotspot/user").add({
                name: target.username,
                password: target.password,
                profile: target.profile
              });
              addSucceeded = true;
              break;
            } catch (addError) {
              lastAddError = addError;
              const addMessage = String(addError?.message || addError || "");
              const alreadyExists = /already have user with this name/i.test(addMessage);
              if (!alreadyExists || addAttempt === 2) {
                break;
              }

              // Jika masih bentrok saat add pertama, paksa cleanup sekali lagi lalu retry add.
              await removeHotspotUsersByName(conn, target.username);
              await new Promise((resolve) => setTimeout(resolve, 300));
            }
          }

          if (!addSucceeded) {
            throw lastAddError || new Error(`Gagal add ulang user ${target.username}`);
          }

          if (!target.pelanggan.resetAkunHistory) target.pelanggan.resetAkunHistory = [];
          target.pelanggan.resetAkunHistory = target.pelanggan.resetAkunHistory
            .filter((rh) => rh.tanggalExpired !== target.tanggalExpiredString);
          target.pelanggan.resetAkunHistory.push({
            tanggalExpired: target.tanggalExpiredString,
            dijalankan: true,
            tanggalDijalankan: todayString,
            jamDijalankan: jamProses
          });
          target.pelanggan.tanggalUpdate = new Date().toISOString();

          dataDiperbarui = true;
          resetSukses++;
          console.log(`[ResetAkun] Removed and re-added user: ${target.username}`);
          console.log(`[ResetAkun] Added user: ${target.username} with profile: ${target.profile}`);
        } catch (error) {
          console.error(`[ResetAkun] Gagal reset akun ${target.username}:`, error?.message || error);
        }
      }

      if (dataDiperbarui) {
        simpanPelanggan(pelangganList);
      }
      console.log(`[ResetAkun] Selesai. Berhasil reset ${resetSukses}/${pendingReset.length} akun.`);
    }, "Gagal reset akun pelanggan sebelum expired");
  } catch (error) {
    console.error('Error dalam kirimResetAkunSebelumExpiredJam3Pagi:', error);
  }
};

const setupCronNotifikasi = () => {
  try {
    if (cronJobNotifikasi) {
      cronJobNotifikasi.stop();
      console.log('[Cron] Cron job lama dihentikan');
    }
    cronJobNotifikasi = new CronJob('0 0 8 * * *', async () => {
      console.log('[Cron] Trigger cron job jam 8 pagi');
      await kirimNotifikasiExpiredJam8Pagi();
    }, null, true, APP_TIMEZONE);
    console.log('[Cron] Cron job dijadwalkan setiap hari jam 8 pagi');
    const nextRun = formatCronNextRun(cronJobNotifikasi);
    console.log(`[Cron] Jadwal berikutnya: ${nextRun || '-'}`);
  } catch (error) {
    console.error('[Cron] Gagal setup cron job:', error);
  }
};

const setupCronResetAkun = () => {
  try {
    if (cronJobResetAkun) {
      cronJobResetAkun.stop();
      console.log('[Cron ResetAkun] Cron job lama dihentikan');
    }
    cronJobResetAkun = new CronJob('0 0 1 * * *', async () => {
      console.log('[Cron ResetAkun] Trigger cron job jam 1 pagi');
      await kirimResetAkunSebelumExpiredJam3Pagi();
    }, null, true, APP_TIMEZONE);
    console.log('[Cron ResetAkun] Cron job dijadwalkan setiap hari jam 1 pagi');
    const nextRun = formatCronNextRun(cronJobResetAkun);
    console.log(`[Cron ResetAkun] Jadwal berikutnya: ${nextRun || '-'}`);
  } catch (error) {
    console.error('[Cron ResetAkun] Gagal setup cron job:', error);
  }
};

const manualTriggerNotifikasi = async (chatId) => {
  try {
    await client.sendMessage(chatId, "Trigger manual notifikasi jam 8 pagi...");
    await kirimNotifikasiExpiredJam8Pagi();
    await client.sendMessage(chatId, "Notifikasi manual selesai dijalankan");
  } catch (error) {
    console.error('[Cron] Error manual trigger:', error);
    await client.sendMessage(chatId, "Gagal menjalankan notifikasi manual");
  }
};

const kirimBroadcastInfo = async (chatId, pesanInfo, denganRiwayat = false) => {
  try {
    const pelangganList = bacaPelanggan();
    if (pelangganList.length === 0) {
      await client.sendMessage(chatId, "Tidak ada pelanggan yang terdaftar.");
      return { total: 0, berhasil: 0, gagal: 0 };
    }
    await client.sendMessage(chatId, `Mempersiapkan broadcast info ke ${pelangganList.length} pelanggan...\n\nPesan: ${pesanInfo.substring(0, 100)}${pesanInfo.length > 100 ? '...' : ''}`);
    const now = new Date();
    const waktuFormat = now.toLocaleString('id-ID');
    const pesanBroadcast = `*INFORMASI LAYANAN EMMERIL HOTSPOT*\n\nYth. Pelanggan Emmeril Hotspot,\n\n${pesanInfo}\n\nTerima kasih atas pengertiannya.\n*Customer Service Emmeril Hotspot*`;
    const targetValid = pelangganList.filter((pelanggan) => pelanggan.nomer && pelanggan.nomer.length >= 10);
    let berhasil = 0;
    let gagal = pelangganList.length - targetValid.length;

    await processInBatches(targetValid, BULK_SEND_CONCURRENCY, async (pelanggan) => {
      try {
        await client.sendMessage(`${pelanggan.nomer}@c.us`, pesanBroadcast);
        berhasil++;
        await new Promise((resolve) => setTimeout(resolve, BULK_SEND_DELAY_MS));
      } catch (error) {
        console.error(`Gagal kirim ke ${pelanggan.nama} (${pelanggan.nomer}):`, error);
        gagal++;
      }
    });
    if (denganRiwayat) {
      tambahRiwayatInfo({ pesan: pesanInfo, total_target: pelangganList.length, berhasil, gagal, pengirim: chatId });
    }
    const hasilMessage = `*LAPORAN BROADCAST INFO*\n\nBerhasil dikirim: ${berhasil} pelanggan\nGagal dikirim: ${gagal} pelanggan\nTotal target: ${pelangganList.length} pelanggan\n\nWaktu: ${waktuFormat}`;
    await client.sendMessage(chatId, hasilMessage);
    return { total: pelangganList.length, berhasil, gagal };
  } catch (error) {
    console.error('Error dalam kirimBroadcastInfo:', error);
    await client.sendMessage(chatId, "Terjadi kesalahan saat mengirim broadcast info.");
    throw error;
  }
};

const lihatRiwayatInfo = async (chatId, limit = 10) => {
  try {
    const riwayat = bacaRiwayatInfo();
    if (riwayat.length === 0) {
      return client.sendMessage(chatId, "Belum ada riwayat broadcast info.");
    }
    let message = `*RIWAYAT BROADCAST INFO*\n\n`;
    const tampilLimit = Math.min(limit, riwayat.length);
    for (let i = 0; i < tampilLimit; i++) {
      const item = riwayat[i];
      const tanggal = new Date(item.tanggal).toLocaleString('id-ID');
      const pesanSingkat = item.pesan.length > 50 ? item.pesan.substring(0, 50) + '...' : item.pesan;
      message += `*${i + 1}. ${tanggal}*\n${pesanSingkat}\nBerhasil: ${item.berhasil}, Gagal: ${item.gagal}, Total: ${item.total_target}\n---\n`;
    }
    message += `\nTotal riwayat: ${riwayat.length}\nGunakan \`#inforiwayat <jumlah>\` untuk melihat lebih banyak.`;
    await client.sendMessage(chatId, message);
  } catch (error) {
    console.error('Error dalam lihatRiwayatInfo:', error);
    await client.sendMessage(chatId, "Terjadi kesalahan saat mengambil riwayat info.");
  }
};

const tambahRiwayatInfo = (infoData) => {
  const riwayat = bacaRiwayatInfo();
  riwayat.unshift({ ...infoData, tanggal: new Date().toISOString() });
  if (riwayat.length > 100) riwayat.splice(100);
  return simpanRiwayatInfo(riwayat);
};

// ==================== PELANGGAN ====================
const tambahPelangganDanAkun = (dataPelanggan) => {
  const pelangganList = bacaPelanggan();
  const existingIndex = pelangganList.findIndex(p => p.username === dataPelanggan.username);
  if (existingIndex > -1) {
    pelangganList[existingIndex] = { ...pelangganList[existingIndex], ...dataPelanggan, tanggalUpdate: new Date().toISOString() };
  } else {
    pelangganList.push({ ...dataPelanggan, tanggalDaftar: new Date().toISOString(), tanggalUpdate: new Date().toISOString() });
  }
  return simpanPelanggan(pelangganList);
};

const cariPelangganByUsername = (username) => {
  const pelangganList = bacaPelanggan();
  return pelangganList.find(p => p.username === username);
};

const hapusPelanggan = (username) => {
  const pelangganList = bacaPelanggan();
  const index = pelangganList.findIndex(p => p.username === username);
  if (index > -1) {
    pelangganList.splice(index, 1);
    return simpanPelanggan(pelangganList);
  }
  return false;
};

// ==================== ADMIN ====================
const isAdmin = (phoneNumber) => {
  const adminList = bacaAdminList();
  return adminList.includes(phoneNumber);
};

const tambahAdmin = (phoneNumber) => {
  const adminList = bacaAdminList();
  const formattedNumber = phoneNumber.replace(/\D/g, '');
  if (!adminList.includes(formattedNumber)) {
    adminList.push(formattedNumber);
    return simpanAdminList(adminList);
  }
  return true;
};

const hapusAdmin = (phoneNumber) => {
  const adminList = bacaAdminList();
  const formattedNumber = phoneNumber.replace(/\D/g, '');
  const index = adminList.indexOf(formattedNumber);
  if (index > -1) {
    adminList.splice(index, 1);
    return simpanAdminList(adminList);
  }
  return false;
};

// ==================== SYNC PELANGGAN ====================
// ==================== PERUBAHAN UTAMA: SYNC MENGGUNAKAN EMAIL DAN MENGISI EMAIL KOSONG ====================
const syncPelangganFromMikrotik = async () => {
  try {
    console.log('[Sync] Memulai sinkronisasi data pelanggan...');
    await executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      if (!users || users.length === 0) {
        console.log('[Sync] Tidak ada user di MikroTik');
        return;
      }
      const pelangganList = bacaPelanggan();
      if (pelangganList.length === 0) {
        console.log('[Sync] Tidak ada data pelanggan di lokal');
        return;
      }
      let updatedCount = 0, notFoundCount = 0, recoveredCount = 0;
      const { userByName, userByEmail } = buildMikrotikUserLookups(users);

      for (const pelanggan of pelangganList) {
        const usernameKey = normalizeUserKey(pelanggan.username);
        if (!usernameKey) {
          notFoundCount++;
          continue;
        }
        // Cari berdasarkan username (case-insensitive)
        let mikrotikUser = userByName.get(usernameKey);

        // Jika tidak ditemukan, cari berdasarkan nomor dari email
        if (!mikrotikUser && pelanggan.nomer) {
          mikrotikUser = userByEmail.get(pelanggan.nomer);
          if (mikrotikUser) {
            console.log(`[Sync] Ditemukan user dengan nomor ${pelanggan.nomer} (email) tetapi username berbeda: lokal=${pelanggan.username}, mikrotik=${mikrotikUser.name}. Memperbarui username lokal.`);
            pelanggan.username = mikrotikUser.name;
            pelanggan.tanggalUpdate = new Date().toISOString();
            updatedCount++;
            recoveredCount++;
          }
        }

        if (mikrotikUser) {
          let updated = false;
          if (pelanggan.status !== 'verified') {
            pelanggan.status = 'verified';
            updated = true;
          }
          const mikrotikPassword = mikrotikUser.password || '';
          const mikrotikProfile = mikrotikUser.profile || '';

          if (pelanggan.password !== mikrotikPassword) {
            console.log(`[Sync] Update password untuk ${pelanggan.username}: ${pelanggan.password} -> ${mikrotikPassword}`);
            pelanggan.password = mikrotikPassword;
            updated = true;
          }
          if (pelanggan.profile !== mikrotikProfile) {
            console.log(`[Sync] Update profile untuk ${pelanggan.username}: ${pelanggan.profile} -> ${mikrotikProfile}`);
            pelanggan.profile = mikrotikProfile;
            updated = true;
          }

          // Sinkronisasi email: pastikan email terisi dan sesuai dengan nomor lokal
          const nomorDariEmail = mikrotikUser.email ? mikrotikUser.email.split('@')[0] : null;
          const emailSesuai = (nomorDariEmail === pelanggan.nomer);
          if (pelanggan.nomer && (!nomorDariEmail || !emailSesuai)) {
            try {
              const targetEmail = buildHotspotEmailFromNomer(pelanggan.nomer);
              // Gunakan filter by name untuk menghindari masalah ID
              await conn.menu("/ip/hotspot/user").where('name', mikrotikUser.name).update({ email: targetEmail });
              console.log(`[Sync] Update email untuk ${pelanggan.username} menjadi ${targetEmail} (sebelumnya: ${mikrotikUser.email || 'kosong'})`);
              updated = true;
            } catch (e) {
              console.error(`[Sync] Gagal update email untuk ${pelanggan.username}:`, e.message);
            }
          }

          if (updated) {
            pelanggan.tanggalUpdate = new Date().toISOString();
            pelanggan.status = 'verified';
            updatedCount++;
          }
        } else {
          console.log(`[Sync] ${pelanggan.username} (${pelanggan.nama}) tidak ditemukan di MikroTik`);
          pelanggan.status = 'not_found_in_mikrotik';
          pelanggan.tanggalUpdate = new Date().toISOString();
          notFoundCount++;
        }
      }

      if (updatedCount > 0 || notFoundCount > 0) {
        const success = simpanPelanggan(pelangganList);
        if (success) {
          state.lastSyncTime = new Date();
          console.log(`[Sync] Selesai. Updated: ${updatedCount} (termasuk ${recoveredCount} pemulihan username), Not Found: ${notFoundCount}`);
          if (updatedCount > 0) {
            kirimNotifikasiSyncKeAdmin(updatedCount, notFoundCount, recoveredCount);
          }
        } else {
          console.error('[Sync] Gagal menyimpan data pelanggan setelah sinkronisasi');
        }
      } else {
        console.log('[Sync] Tidak ada perubahan');
      }
    }, "Gagal sinkronisasi");
  } catch (error) {
    console.error('[Sync] Error:', error);
  }
};

const cekPerbedaanPelanggan = async (chatId) => {
  try {
    await executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      const pelangganList = bacaPelanggan();
      if (pelangganList.length === 0) {
        await client.sendMessage(chatId, "Tidak ada data pelanggan di lokal.");
        return;
      }
      const { userByName, userByEmail } = buildMikrotikUserLookups(users);
      let message = `*PERBEDAAN DATA PELANGGAN*\n\nTotal pelanggan di lokal: ${pelangganList.length}\n`;
      let adaPerbedaan = false, passwordBerbeda = 0, profileBerbeda = 0, tidakDitemukan = 0;
      for (const pelanggan of pelangganList) {
        const usernameKey = normalizeUserKey(pelanggan.username);
        if (!usernameKey) {
          tidakDitemukan++;
          adaPerbedaan = true;
          message += `*(tanpa username)*: Data lokal tidak valid\n`;
          continue;
        }

        let mikrotikUser = userByName.get(usernameKey);
        if (!mikrotikUser && pelanggan.nomer) {
          mikrotikUser = userByEmail.get(pelanggan.nomer);
        }
        if (!mikrotikUser) {
          tidakDitemukan++;
          if (!adaPerbedaan) adaPerbedaan = true;
          message += `*${pelanggan.username}*: Tidak ditemukan di MikroTik\n`;
          continue;
        }
        let perbedaan = [];
        if (normalizeUserKey(mikrotikUser.name) !== usernameKey) {
          perbedaan.push(`username: ${pelanggan.username} -> ${mikrotikUser.name}`);
        }
        if (pelanggan.password !== mikrotikUser.password) {
          passwordBerbeda++;
          perbedaan.push(`password: ${pelanggan.password} -> ${mikrotikUser.password}`);
        }
        if (pelanggan.profile !== mikrotikUser.profile) {
          profileBerbeda++;
          perbedaan.push(`profile: ${pelanggan.profile} -> ${mikrotikUser.profile}`);
        }
        if (perbedaan.length > 0) {
          if (!adaPerbedaan) adaPerbedaan = true;
          message += `*${pelanggan.username}*: ${perbedaan.join(', ')}\n`;
        }
      }
      if (!adaPerbedaan) {
        message += `\nTidak ada perbedaan untuk semua pelanggan.\n`;
      } else {
        message += `\nRingkasan:\n`;
        if (tidakDitemukan > 0) message += `- Tidak ditemukan: ${tidakDitemukan}\n`;
        if (passwordBerbeda > 0) message += `- Password berbeda: ${passwordBerbeda}\n`;
        if (profileBerbeda > 0) message += `- Profile berbeda: ${profileBerbeda}\n`;
      }
      message += `\nGunakan \`#syncpelanggan\` untuk melakukan sinkronisasi.`;
      await client.sendMessage(chatId, message);
    }, "Gagal cek perbedaan");
  } catch (error) {
    console.error('[Sync] Error cek perbedaan:', error);
    await client.sendMessage(chatId, "Gagal cek perbedaan.");
  }
};

const perbaikiPelanggan = async (chatId, username, nomer) => {
  try {
    const pelangganList = bacaPelanggan();
    const usernameKey = String(username || "").toLowerCase();
    const index = pelangganList.findIndex((p) => String(p.username || "").toLowerCase() === usernameKey);
    if (index === -1) {
      return client.sendMessage(chatId, `${username} tidak ditemukan di data pelanggan.`);
    }
    const formattedNomer = nomer.replace(/\D/g, '');
    if (!formattedNomer.startsWith('62')) {
      return client.sendMessage(chatId, `Format nomor harus 62xxxxxxxxxx`);
    }
    const pelanggan = pelangganList[index];
    const nomorLama = pelanggan.nomer || '-';
    pelanggan.nomer = formattedNomer;
    pelanggan.tanggalUpdate = new Date().toISOString();
    pelanggan.status = 'verified';
    if (simpanPelanggan(pelangganList)) {
      let mikrotikSyncMessage = 'Perubahan email hotspot akan ikut tersinkron saat auto sync berikutnya.';
      try {
        await executeWithMikrotik(async (conn) => {
          const users = await conn.menu("/ip/hotspot/user").print();
          const mikrotikUser = users.find((user) => String(user.name || "").toLowerCase() === usernameKey);
          if (!mikrotikUser) {
            mikrotikSyncMessage = 'User hotspot tidak ditemukan di MikroTik, jadi email belum diperbarui.';
            return;
          }

          const targetEmail = buildHotspotEmailFromNomer(formattedNomer);
          if (String(mikrotikUser.email || "").trim() === targetEmail) {
            mikrotikSyncMessage = 'Email hotspot di MikroTik sudah sesuai.';
            return;
          }

          await conn.menu("/ip/hotspot/user").where('name', mikrotikUser.name).update({ email: targetEmail });
          mikrotikSyncMessage = `Email hotspot di MikroTik ikut diperbarui ke ${targetEmail}.`;
        }, "Gagal sinkron nomor pelanggan ke email hotspot");
      } catch (syncError) {
        console.error(`[Sync] Gagal sinkron nomor pelanggan ${pelanggan.username} ke MikroTik:`, syncError);
      }

      await client.sendMessage(
        chatId,
        `Nomor untuk ${pelanggan.username} diperbarui:\n${nomorLama} -> ${formattedNomer}\n\n${mikrotikSyncMessage}`
      );
    } else {
      await client.sendMessage(chatId, "Gagal menyimpan perubahan nomor pelanggan.");
    }
  } catch (error) {
    console.error('[Sync] Error perbaiki:', error);
    await client.sendMessage(chatId, "Gagal memperbarui.");
  }
};

const manualSyncPelanggan = async (chatId) => {
  try {
    await client.sendMessage(chatId, "Sync data pelanggan (hanya yang ada di data lokal)...");
    await syncPelangganFromMikrotik();
    const pelangganList = bacaPelanggan();
    await client.sendMessage(chatId, `Sync selesai!\nTotal pelanggan: ${pelangganList.length}`);
  } catch (error) {
    console.error('[Sync] Error manual sync:', error);
    await client.sendMessage(chatId, "Gagal sync.");
  }
};

// ==================== NOTIFIKASI DENGAN RECOVERED COUNT ====================
const kirimNotifikasiSyncKeAdmin = async (updatedCount, notFoundCount, recoveredCount = 0) => {
  try {
    if (!state.isReady) return;
    const adminList = bacaAdminList();
    const now = new Date();
    const waktu = now.toLocaleString('id-ID');
    let message = `*NOTIFIKASI SINKRONISASI*\n\nData pelanggan telah disinkronisasi dari MikroTik\nWaktu: ${waktu}\nDiperbarui: ${updatedCount} pelanggan`;
    if (recoveredCount > 0) {
      message += ` (${recoveredCount} username diperbaiki)`;
    }
    message += `\nTidak ditemukan: ${notFoundCount} pelanggan\n\nGunakan \`#daftarpelanggan\` untuk melihat daftar terbaru.\nGunakan \`#perbaiki <username> <nomor>\` untuk memperbaiki nomor.`;
    for (const adminNumber of adminList) {
      try {
        await client.sendMessage(`${adminNumber}@c.us`, message);
        console.log(`[Sync] Notifikasi dikirim ke admin ${adminNumber}`);
        await new Promise(resolve => setTimeout(resolve, 1000));
      } catch (error) {
        console.error(`[Sync] Gagal kirim notifikasi ke ${adminNumber}:`, error);
      }
    }
  } catch (error) {
    console.error('[Sync] Error kirim notifikasi:', error);
  }
};

// ==================== WHATSAPP CLIENT ====================
const createWhatsAppClient = () => {
  console.log("Creating WhatsApp client...");
  return new Client({
    authStrategy: new LocalAuth({ dataPath: WWEBJS_AUTH_DIR }),
    puppeteer: {
      executablePath: getPuppeteerExecutablePath(),
      headless: true,
      args: [
        "--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage",
        "--disable-accelerated-2d-canvas", "--no-first-run", "--no-zygote",
        "--disable-gpu", "--disable-software-rasterizer", "--disable-features=VizDisplayCompositor",
        "--disable-background-timer-throttling", "--disable-backgrounding-occluded-windows",
        "--disable-renderer-backgrounding", "--max-old-space-size=512"
      ],
      ignoreHTTPSErrors: true,
    },
    webVersionCache: {
      type: "remote",
      remotePath: "https://raw.githubusercontent.com/wppconnect-team/wa-version/refs/heads/main/html/2.3000.1031490220-alpha.html",
    },
  });
};

const scheduleReconnect = (force = false) => {
  if (!force && state.isReconnecting) {
    console.log("[WA] Reconnect already running, skip");
    return false;
  }
  const now = Date.now();
  if (!force && state.lastReconnectTime && now - state.lastReconnectTime < MIN_RECONNECT_INTERVAL) {
    const wait = Math.ceil((MIN_RECONNECT_INTERVAL - (now - state.lastReconnectTime)) / 1000);
    console.log(`[WA] Wait ${wait}s before reconnect`);
    return false;
  }
  if (!force && state.reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
    console.error("Max reconnect attempts reached");
    return false;
  }
  if (force) {
    state.reconnectAttempts = 0;
    state.isReconnecting = false;
  }
  state.reconnectAttempts++;
  state.lastReconnectTime = now;
  state.isReconnecting = true;
  const delay = Math.min(30000, RECONNECT_DELAY * Math.pow(2, state.reconnectAttempts));
  console.log(`Reconnect in ${delay / 1000}s (${state.reconnectAttempts}/${MAX_RECONNECT_ATTEMPTS})`);
  clearTimeout(state.reconnectTimer);
  state.reconnectTimer = setTimeout(async () => {
    try {
      if (client) {
        console.log("Destroying WhatsApp client");
        await client.destroy().catch(() => {});
        client = null;
      }
      console.log("[WA] Creating new WhatsApp client");
      client = createWhatsAppClient();
      setupWhatsAppEvents();
      console.log("[WA] Initializing WhatsApp");
      await client.initialize();
    } catch (err) {
      console.error("Reconnect failed:", err.message);
      state.isReconnecting = false;
      scheduleReconnect();
      return;
    } finally {
      setTimeout(() => {
        if (!state.isReady) {
          state.isReconnecting = false;
        }
      }, 15000);
    }
  }, delay);
  return true;
};

const startWhatsAppKeepAlive = () => {
  if (state.keepAliveTimer) return;
  state.keepAliveTimer = setInterval(async () => {
    if (!client || !state.isReady) return;
    try {
      await client.getState();
      state.reconnectAttempts = 0;
      console.log("WA keep-alive OK");
    } catch {
      console.log("WA keep-alive failed");
      state.isReady = false;
      scheduleReconnect();
    }
  }, 300000); // 5 menit
};

const clearRuntimeIntervals = () => {
  if (state.autoRekapInterval) {
    clearInterval(state.autoRekapInterval);
    state.autoRekapInterval = null;
  }
  if (state.syncPelangganInterval) {
    clearInterval(state.syncPelangganInterval);
    state.syncPelangganInterval = null;
  }
  if (state.autoBackupInterval) {
    clearInterval(state.autoBackupInterval);
    state.autoBackupInterval = null;
  }
  if (state.keepAliveTimer) {
    clearInterval(state.keepAliveTimer);
    state.keepAliveTimer = null;
  }
  if (state.infoConfirmations.size > 0) {
    for (const [, pending] of state.infoConfirmations) {
      if (pending?.timeoutId) {
        clearTimeout(pending.timeoutId);
      }
      if (pending?.handler && client) {
        client.removeListener('message', pending.handler);
      }
    }
    state.infoConfirmations.clear();
  }
};

// ==================== COMMAND HANDLERS ====================
const commandHandlers = {
  async bantuan(chatId) {
    const menu = `*MikroTik Hotspot Bot - Daftar Perintah:*\n\n` +
      `*#bantuan* - Menampilkan daftar perintah\n` +
      `*#info <pesan>* - Broadcast info gangguan/perbaikan ke semua pelanggan\n` +
      `*#infotest <pesan>* - Test broadcast tanpa mengirim\n` +
      `*#inforiwayat [limit]* - Lihat riwayat broadcast info\n` +
      `*#useractive* - Menampilkan user hotspot aktif\n` +
      `*#monitorap* - Menampilkan status Access Point\n` +
      `*#userprofile* - Jumlah user per profile\n` +
      `*#cariuser <username>* - Cari user berdasarkan nama\n` +
      `*#cekprofile* - Daftar profile hotspot\n` +
      `*#addprofile <nama> <durasi> [rx] [tx] [lock/unlock]* - Buat profil hotspot baru\n` +
      `*#setharga <profile> <harga>* - Set harga untuk profile\n` +
      `*#daftarharga* - Lihat daftar harga profile\n` +
      `*#backup* - Backup user aktif ke history\n` +
      `*#rekap harian* - Rekap pendapatan harian (Excel)\n` +
      `*#rekap bulanan* - Rekap pendapatan bulanan (Excel)\n` +
      `*#rekap <dd-mm-yyyy>* - Rekap tanggal spesifik (Excel)\n` +
      `*#rekap <mm-yyyy>* - Rekap bulan spesifik (Excel)\n` +
      `*#autorekap <on/off> [menit]* - Auto rekap otomatis\n` +
      `*#statusautorekap* - Status auto rekap\n` +
      `*#adduser <username> <password> <profile>* - Tambah user baru\n` +
      `*#generate [prefix] <profile> <jumlah>* - Generate user massal + Excel\n` +
      `*#addpelanggan <nama> <nomer> <profile>* - Buat akun pelanggan baru\n` +
      `*#daftarpelanggan* - Lihat daftar pelanggan\n` +
      `*#hapuspelanggan <username>* - Hapus data pelanggan\n` +
      `*#notifmanual <username>* - Kirim notifikasi manual\n` +
      `*#addadmin <nomor>* - Tambah admin baru\n` +
      `*#removeadmin <nomor>* - Hapus admin\n` +
      `*#listadmin* - Lihat daftar admin\n` +
      `*#syncpelanggan* - Sync data pelanggan dari MikroTik\n` +
      `*#ceksync* - Cek perbedaan data \n` +
      `*#perbaiki <username> <nomor>* - Perbaiki nomor pelanggan\n` +
      `*#restart* - Restart bot WhatsApp\n` +
      `*#testnotif* - Test notifikasi jam 8 pagi\n` +
      `*#cronstatus* - Status cron job\n\n` +
      `Contoh:\n` +
      `#info Layanan sedang gangguan, perbaikan selesai jam 14.00 WIB\n` +
      `#infotest Maintenance jaringan hari Minggu\n` +
      `#inforiwayat 5\n` +
      `#cariuser john\n` +
      `#addprofile 4-JAM 4h\n` +
      `#addprofile VIP-USER 1d 2M 1M\n` +
      `#setharga 4-JAM 4000\n` +
      `#backup\n` +
      `#rekap harian\n` +
      `#autorekap on 1\n` +
      `#generate 4-JAM 50\n` +
      `#addpelanggan John Doe 6281234567890 4-JAM\n` +
      `#addadmin 6281234567890\n` +
      `#syncpelanggan\n` +
      `#perbaiki johndoe 6281234567890`;
    await client.sendMessage(chatId, menu);
  },

  async info(chatId, args, senderNumber) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#info <pesan>`\n\nContoh: `#info Layanan sedang gangguan...`");
    }

    const existingConfirmation = state.infoConfirmations.get(senderNumber);
    if (existingConfirmation?.timeoutId) {
      clearTimeout(existingConfirmation.timeoutId);
    }
    if (existingConfirmation?.handler) {
      client.removeListener('message', existingConfirmation.handler);
    }
    state.infoConfirmations.delete(senderNumber);

    const konfirmasiPesan = `*KONFIRMASI BROADCAST INFO*\n\nPesan: ${args}\n\nAkan dikirim ke semua pelanggan.\n\nBalas dengan *YA* untuk melanjutkan atau *TIDAK* untuk membatalkan.`;
    await client.sendMessage(chatId, konfirmasiPesan);
    const confirmHandler = async (confirmMsg) => {
      if (confirmMsg.from.split('@')[0] === senderNumber && confirmMsg.from === chatId) {
        const response = confirmMsg.body.trim().toLowerCase();
        if (response === 'ya' || response === 'y') {
          const pending = state.infoConfirmations.get(senderNumber);
          if (pending?.timeoutId) {
            clearTimeout(pending.timeoutId);
          }
          client.removeListener('message', confirmHandler);
          state.infoConfirmations.delete(senderNumber);
          await client.sendMessage(chatId, "Mengirim broadcast info...");
          await mikrotikOperations.kirimBroadcastInfo(chatId, args);
        } else if (response === 'tidak' || response === 't') {
          const pending = state.infoConfirmations.get(senderNumber);
          if (pending?.timeoutId) {
            clearTimeout(pending.timeoutId);
          }
          client.removeListener('message', confirmHandler);
          state.infoConfirmations.delete(senderNumber);
          await client.sendMessage(chatId, "Broadcast info dibatalkan.");
        }
      }
    };
    client.on('message', confirmHandler);
    const timeoutId = setTimeout(() => {
      const pending = state.infoConfirmations.get(senderNumber);
      if (!pending || pending.handler !== confirmHandler) return;
      client.removeListener('message', confirmHandler);
      state.infoConfirmations.delete(senderNumber);
      client.sendMessage(chatId, "Waktu konfirmasi habis. Broadcast dibatalkan.").catch((error) => {
        console.error("Gagal kirim timeout konfirmasi info:", error);
      });
    }, 30000);
    state.infoConfirmations.set(senderNumber, { handler: confirmHandler, timeoutId, chatId });
  },

  async infotest(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#infotest <pesan>`\nContoh: `#infotest Layanan sedang gangguan...`");
    }
    await mikrotikOperations.testBroadcastInfo(chatId, args);
  },

  async inforiwayat(chatId, args) {
    const parsedLimit = parsePositiveInt(args, { min: 1, max: 50 });
    const limit = parsedLimit ?? 10;
    await mikrotikOperations.lihatRiwayatInfo(chatId, limit);
  },

  async useractive(chatId) {
    await client.sendMessage(chatId, "Mengambil data user aktif...");
    await mikrotikOperations.getActiveHotspotUsers(chatId);
  },

  async monitorap(chatId) {
    await client.sendMessage(chatId, "Memantau status AP...");
    await mikrotikOperations.getNetwatchStatus(chatId, true);
  },

  async userprofile(chatId) {
    await client.sendMessage(chatId, "Menghitung user per profile...");
    await mikrotikOperations.getTotalUserProfileCounts(chatId);
  },

  async cariuser(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#cariuser <username>`");
    }
    await client.sendMessage(chatId, `Mencari user: "${args}"...`);
    await mikrotikOperations.findUserByName(chatId, args);
  },

  async cekprofile(chatId) {
    await client.sendMessage(chatId, "Mengambil daftar profile...");
    await mikrotikOperations.getHotspotProfiles(chatId);
  },

  async addprofile(chatId, args) {
    const parts = splitArgs(args);
    if (parts.length < 2) {
      return client.sendMessage(chatId, "Format: `#addprofile <nama_profile> <durasi> [rx_limit] [tx_limit] [lock/unlock]`\nContoh: `#addprofile 4-JAM 4h`");
    }
    const profileName = parts[0];
    const duration = parts[1];
    if (!VALID_PROFILE_DURATIONS.has(duration)) {
      return client.sendMessage(chatId, `Durasi tidak valid. Gunakan salah satu: ${Array.from(VALID_PROFILE_DURATIONS).join(', ')}`);
    }
    let rxLimit = null, txLimit = null, lockMode = "lock";
    if (parts.length >= 3) {
      const lastParam = parts[parts.length - 1].toLowerCase();
      if (lastParam === "lock" || lastParam === "unlock") {
        lockMode = lastParam;
        parts.pop();
      }
      if (parts.length === 4) {
        rxLimit = parts[2];
        txLimit = parts[3];
        if (!BANDWIDTH_LIMIT_REGEX.test(rxLimit) || !BANDWIDTH_LIMIT_REGEX.test(txLimit)) {
          return client.sendMessage(chatId, `Format limit tidak valid. Gunakan format seperti: 1M, 500k, 2G`);
        }
      } else if (parts.length !== 2) {
        return client.sendMessage(chatId, "Format: `#addprofile <nama_profile> <durasi> [rx_limit] [tx_limit] [lock/unlock]`\nContoh: `#addprofile 4-JAM 4h`\nContoh lain: `#addprofile VIP 1d 2M 1M unlock`");
      }
    }
    let infoMessage = `Membuat profil "${profileName}" dengan durasi ${duration}`;
    if (rxLimit && txLimit) infoMessage += ` dan limit ${rxLimit} download / ${txLimit} upload`;
    infoMessage += ` (MAC address: ${lockMode.toUpperCase()})...`;
    await client.sendMessage(chatId, infoMessage);
    await mikrotikOperations.addHotspotProfile(chatId, profileName, duration, rxLimit, txLimit, lockMode);
  },

  async setharga(chatId, args) {
    const parts = splitArgs(args);
    if (parts.length !== 2) {
      return client.sendMessage(chatId, "Format: `#setharga <profile> <harga>`\nContoh: `#setharga 4-JAM 4000`");
    }
    const [profileName, hargaStr] = parts;
    const harga = Number.parseInt(hargaStr.replace(/[^\d]/g, ''), 10);
    if (Number.isNaN(harga) || harga <= 0) {
      return client.sendMessage(chatId, "Harga harus angka positif.");
    }
    await client.sendMessage(chatId, `Menyetel harga profil "${profileName}" menjadi Rp ${harga.toLocaleString('id-ID')}...`);
    await mikrotikOperations.setHargaProfil(chatId, profileName, harga);
  },

  async daftarharga(chatId) {
    await client.sendMessage(chatId, "Mengambil daftar harga...");
    await mikrotikOperations.getDaftarHarga(chatId);
  },

  async backup(chatId) {
    await client.sendMessage(chatId, "Melakukan backup user ke history...");
    const backupResult = await mikrotikOperations.backupUserHistory(chatId);
    if (!backupResult) {
      await client.sendMessage(chatId, "Backup selesai tanpa hasil yang bisa dipastikan. Cek log untuk detail.");
      return;
    }

    if (backupResult.reason === 'saved') {
      await client.sendMessage(chatId, `Backup history berhasil dilakukan. Data baru: ${backupResult.inserted}, diperbarui: ${backupResult.updated}.`);
      return;
    }

    if (backupResult.reason === 'no_valid_data') {
      await client.sendMessage(chatId, "Backup selesai, tetapi tidak ada data user valid yang bisa disimpan ke history.");
      return;
    }

    if (backupResult.reason === 'save_failed') {
      await client.sendMessage(chatId, "Data backup ditemukan, tetapi gagal disimpan ke file history.");
      return;
    }

    await client.sendMessage(chatId, "Backup selesai. Tidak ada perubahan data history.");
  },

  async rekap(chatId, args) {
    const rekapOptions = parseRekapArgs(args);
    if (!rekapOptions) {
      await client.sendMessage(chatId, `*Format Perintah Rekap:*\n\n#rekap harian\n#rekap bulanan\n#rekap 25-11-2024\n#rekap 10-2024`);
      return;
    }

    if (rekapOptions.mode === 'harian') {
      await client.sendMessage(chatId, "Membuat rekap pendapatan harian berdasarkan tanggal aktif (dari expired comment)...");
    } else if (rekapOptions.mode === 'bulanan') {
      await client.sendMessage(chatId, "Membuat rekap pendapatan bulanan berdasarkan tanggal aktif (dari expired comment)...");
    } else if (rekapOptions.tanggal) {
      await client.sendMessage(chatId, `Membuat rekap untuk tanggal aktif ${rekapOptions.tanggal}...`);
    } else {
      await client.sendMessage(chatId, `Membuat rekap untuk bulan aktif ${rekapOptions.bulan}-${rekapOptions.tahun}...`);
    }
    await mikrotikOperations.getRekapPendapatan(chatId, rekapOptions);
  },

  async autorekap(chatId, args) {
    const parts = splitArgs(args);
    const action = parts[0];
    if (action === "on") {
      let interval = 1;
      if (parts.length > 1) {
        interval = parsePositiveInt(parts[1], { min: 1 });
        if (interval === null) {
          return client.sendMessage(chatId, "Interval harus angka positif (dalam menit).\nContoh: `#autorekap on 5`");
        }
      }
      await client.sendMessage(chatId, `Mengaktifkan auto rekap setiap ${interval} menit...`);
      await mikrotikOperations.setAutoRekap(chatId, true, interval);
    } else if (action === "off") {
      await client.sendMessage(chatId, "Menonaktifkan auto rekap...");
      await mikrotikOperations.setAutoRekap(chatId, false);
    } else {
      await client.sendMessage(chatId, "Format: `#autorekap <on/off> [menit]`");
    }
  },

  async statusautorekap(chatId) {
    await mikrotikOperations.getStatusAutoRekap(chatId);
  },

  async adduser(chatId, args) {
    const parts = splitArgs(args);
    if (parts.length === 2) {
      // Hanya username dan password, minta profile
      await mikrotikOperations.getHotspotProfiles(chatId);
    } else if (parts.length === 3) {
      const [username, password, profile] = parts;
      await client.sendMessage(chatId, `Menambah user ${username} dengan profile ${profile}...`);
      await mikrotikOperations.addUserToHotspot(chatId, username, password, profile);
    } else {
      await client.sendMessage(chatId, "Format: `#adduser <username> <password> <profile>`");
    }
  },

  async generate(chatId, args) {
    const parts = splitArgs(args);
    let prefix = "";
    let profileName = "";
    let countStr = "";
    if (parts.length === 2) {
      [profileName, countStr] = parts;
    } else if (parts.length === 3) {
      [prefix, profileName, countStr] = parts;
    } else {
      await client.sendMessage(chatId, "Format: `#generate [prefix] <profile> <jumlah>`");
      return;
    }

    const count = parsePositiveInt(countStr, { min: 1 });
    if (count === null) {
      return client.sendMessage(chatId, "Jumlah user harus angka positif.");
    }

    if (prefix) {
      await client.sendMessage(chatId, `Generate ${count} user dengan prefix "${prefix}" dan profile "${profileName}"...`);
    } else {
      await client.sendMessage(chatId, `Generate ${count} user dengan profile "${profileName}"...`);
    }
    await mikrotikOperations.generateBulkUsers(chatId, profileName, count, prefix);
  },

  async addpelanggan(chatId, args) {
    const parts = splitArgs(args);
    if (parts.length < 3) {
      return client.sendMessage(chatId, "Format: `#addpelanggan <nama lengkap> <nomer> <profile>`\nContoh: `#addpelanggan John Doe 6281234567890 4-JAM`");
    }
    const profile = parts[parts.length - 1];
    const nomer = parts[parts.length - 2];
    const nama = parts.slice(0, parts.length - 2).join(' ');
    await client.sendMessage(chatId, `Membuat akun untuk pelanggan ${nama}...`);
    await mikrotikOperations.addPelanggan(chatId, nama, nomer, profile);
  },

  async daftarpelanggan(chatId) {
    await mikrotikOperations.getDaftarPelanggan(chatId);
  },

  async hapuspelanggan(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#hapuspelanggan <username>`");
    }
    await client.sendMessage(chatId, `Menghapus pelanggan dengan username "${args}"...`);
    await mikrotikOperations.hapusPelanggan(chatId, args);
  },

  async notifmanual(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#notifmanual <username>`");
    }
    await client.sendMessage(chatId, `Mengirim notifikasi manual untuk "${args}"...`);
    await mikrotikOperations.kirimNotifikasiManual(chatId, args);
  },

  async addadmin(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#addadmin <nomor>`\nContoh: `#addadmin 6281234567890`");
    }
    await client.sendMessage(chatId, `Menambahkan nomor ${args} sebagai admin...`);
    await mikrotikOperations.addAdmin(chatId, args);
  },

  async removeadmin(chatId, args) {
    if (!args) {
      return client.sendMessage(chatId, "Format: `#removeadmin <nomor>`\nContoh: `#removeadmin 6281234567890`");
    }
    await client.sendMessage(chatId, `Menghapus nomor ${args} dari daftar admin...`);
    await mikrotikOperations.removeAdmin(chatId, args);
  },

  async listadmin(chatId) {
    await mikrotikOperations.getAdminList(chatId);
  },

  async syncpelanggan(chatId) {
    await mikrotikOperations.syncPelanggan(chatId);
  },

  async ceksync(chatId) {
    await client.sendMessage(chatId, "Memeriksa perbedaan data pelanggan...");
    await mikrotikOperations.cekPerbedaanPelanggan(chatId);
  },

  async perbaiki(chatId, args) {
    const parts = splitArgs(args);
    if (parts.length !== 2) {
      return client.sendMessage(chatId, "Format: `#perbaiki <username> <nomor>`\nContoh: `#perbaiki johndoe 6281234567890`");
    }
    const [username, nomer] = parts;
    await mikrotikOperations.perbaikiPelanggan(chatId, username, nomer);
  },

  async testnotif(chatId) {
    await manualTriggerNotifikasi(chatId);
  },

  async cronstatus(chatId) {
    const notifikasiAktif = !!cronJobNotifikasi;
    const resetAkunAktif = !!cronJobResetAkun;

    if (!notifikasiAktif && !resetAkunAktif) {
      return client.sendMessage(chatId, "Cron job tidak aktif");
    }

    const nextNotif = notifikasiAktif ? (formatCronNextRun(cronJobNotifikasi) || '-') : '-';
    const nextReset = resetAkunAktif ? (formatCronNextRun(cronJobResetAkun) || '-') : '-';
    const message = `*Status Cron Job*\n\n` +
      `Notifikasi Expired (08:00): ${notifikasiAktif ? 'Aktif' : 'Tidak aktif'}\n` +
      `Berikutnya: ${nextNotif}\n\n` +
      `Reset Akun Sebelum Expired (01:00): ${resetAkunAktif ? 'Aktif' : 'Tidak aktif'}\n` +
      `Berikutnya: ${nextReset}\n\n` +
      `Timezone: ${APP_TIMEZONE}`;
    await client.sendMessage(chatId, message);
  },

  async restart(chatId) {
    await client.sendMessage(chatId, "Merestart WhatsApp client...");
    state.isReady = false;
    clearRuntimeIntervals();
    clearTimeout(state.reconnectTimer);
    state.reconnectTimer = null;
    setTimeout(() => scheduleReconnect(true), 2000);
  }
};

// ==================== WHATSAPP EVENT HANDLERS ====================
const setupWhatsAppEvents = () => {
  if (!client) {
    console.error("Cannot setup events: client is null");
    return;
  }
  client.removeAllListeners();

  client.on("qr", (qr) => {
    state.currentQR = qr;
    state.isReady = false;
    state.reconnectAttempts = 0;
    state.isReconnecting = false;
    console.log("QR code generated");
  });

  client.on("authenticated", () => {
    console.log("WhatsApp authenticated");
    state.reconnectAttempts = 0;
    state.isReconnecting = false;
  });

  client.on("auth_failure", (msg) => {
    console.error("Auth failure:", msg);
    state.isReady = false;
    state.isReconnecting = false;
    scheduleReconnect();
  });

  client.on("ready", () => {
    console.log("WhatsApp ready");
    state.isReady = true;
    state.currentQR = null;
    state.reconnectAttempts = 0;
    state.isReconnecting = false;
    state.lastReconnectTime = null;
    state.restartCount = 0;
    if (state.reconnectTimer) {
      clearTimeout(state.reconnectTimer);
      state.reconnectTimer = null;
    }

    const autoRekapSetting = bacaAutoRekapSetting();
    if (autoRekapSetting.enabled) {
      state.autoRekapEnabled = true;
      startAutoRekapInterval(adminNumber ? `${adminNumber}@c.us` : null, autoRekapSetting.interval);
      console.log(`Auto rekap diaktifkan dengan interval ${autoRekapSetting.interval} menit`);
    } else {
      state.autoRekapEnabled = false;
    }

    // Auto backup setiap 30 menit
    if (state.autoBackupInterval) {
      clearInterval(state.autoBackupInterval);
    }
    state.autoBackupInterval = setInterval(async () => {
      if (state.isReady) {
        console.log("[AutoBackup] Menjalankan backup otomatis (hanya user baru)...");
        try {
          await executeWithMikrotik(async (conn) => {
            const users = await conn.menu("/ip/hotspot/user").print();
            if (!users) return;
            const existingHistory = bacaHistoryUser();
            const historyCandidates = [];
            users.forEach(user => {
              const expiredDate = parseExpiredDateFromComment(user.comment);
              if (expiredDate) {
                historyCandidates.push({
                  name: user.name,
                  profile: user.profile,
                  comment: user.comment,
                  tanggalExpired: expiredDate.toISOString(),
                  password: user.password || '',
                });
              }
            });

            if (historyCandidates.length === 0) return;

            const { history, inserted, updated, changed } = upsertHistoryUsers(historyCandidates, existingHistory);
            if (changed) {
              simpanHistoryUser(history);
              console.log(`[AutoBackup] ${inserted} baru, ${updated} diupdate`);
            }
          }, "Gagal auto backup");
        } catch (error) {
          console.error("[AutoBackup] Gagal:", error);
        }
      }
    }, 30 * 60 * 1000);

    setupCronNotifikasi();
    setupCronResetAkun();
    const now = new Date();
    const currentHour = getHourInTimezone(now, APP_TIMEZONE);
    if (currentHour !== null && currentHour >= 1) {
      console.log('[Cron ResetAkun] Sudah lewat jam 1 pagi, menjalankan reset akun sekarang...');
      setTimeout(kirimResetAkunSebelumExpiredJam3Pagi, 15000);
    }
    if (currentHour !== null && currentHour >= 8) {
      console.log('[Cron] Sudah lewat jam 8 pagi, menjalankan notifikasi sekarang...');
      setTimeout(kirimNotifikasiExpiredJam8Pagi, 30000);
    }

    // Auto sync setiap 30 menit
    console.log("Auto sync pelanggan diaktifkan setiap 30 menit");
    if (state.syncPelangganInterval) {
      clearInterval(state.syncPelangganInterval);
    }
    state.syncPelangganInterval = setInterval(async () => {
      if (state.isReady && state.syncPelangganEnabled) {
        console.log("[AutoSync] Menjalankan sync pelanggan...");
        try {
          await syncPelangganFromMikrotik();
        } catch (error) {
          console.error("[AutoSync] Gagal:", error);
        }
      }
    }, 30 * 60 * 1000);
    setTimeout(() => {
      if (state.isReady) syncPelangganFromMikrotik().catch(console.error);
    }, 30000);

    startWhatsAppKeepAlive();
  });

  client.on("change_state", (newState) => {
    state.waState = newState;
    console.log("WA STATE:", newState);
    if (newState === "CONNECTED") {
      state.isReady = true;
      state.reconnectAttempts = 0;
      state.isReconnecting = false;
    }
    if (["DISCONNECTED", "CONFLICT"].includes(newState)) {
      state.isReady = false;
      clearRuntimeIntervals();
      scheduleReconnect();
    }
  });

  client.on("disconnected", (reason) => {
    console.log("WhatsApp disconnected:", reason);
    state.isReady = false;
    state.currentQR = null;
    clearRuntimeIntervals();
    if (["UNAUTHORIZED", "CONFLICT"].includes(reason)) {
      try {
        fs.rmSync(WWEBJS_AUTH_DIR, { recursive: true, force: true });
        console.log("Session cleared");
      } catch {}
    }
    scheduleReconnect();
  });

  client.on("error", (error) => {
    console.error("WhatsApp error:", error.message);
    if (!state.isReady && !state.isReconnecting) {
      scheduleReconnect();
    }
  });

  client.on("loading_screen", (percent, message) => {
    console.log(`[LOADING] ${percent}% ${message}`);
  });

  // Message handler
  client.on("message", async (msg) => {
    const senderNumber = msg.from.split("@")[0];
    if (!isAdmin(senderNumber)) {
      console.log(`Akses ditolak untuk nomor: ${senderNumber}`);
      return;
    }
    const chatId = msg.from;
    const parsedCommand = parseCommandPayload(msg.body);
    if (!parsedCommand) return; // abaikan pesan biasa
    const { command, args } = parsedCommand;

    try {
      const handler = commandHandlers[command];
      if (handler) {
        await handler(chatId, args, senderNumber);
      } else {
        // command tidak dikenal, mungkin tampilkan bantuan
        await client.sendMessage(chatId, "Perintah tidak dikenal. Ketik #bantuan untuk melihat daftar perintah.");
      }
    } catch (error) {
      console.error("Error processing message:", error);
      await client.sendMessage(chatId, "Terjadi kesalahan saat memproses perintah.");
    }
  });
};

const initializeWhatsApp = () => {
  if (!client) {
    client = createWhatsAppClient();
    setupWhatsAppEvents();
  }
  client.initialize().catch((error) => {
    console.error("Failed to initialize WhatsApp:", error.message);
    state.isReconnecting = false;
    scheduleReconnect();
  });
};

// ==================== EXPRESS ROUTES ====================
app.get("/qr", async (req, res) => {
  if (state.isReady) {
    return res.send(`<html><body style="font-family:sans-serif;padding:20px;text-align:center;color:green;">WhatsApp sudah terhubung.</body></html>`);
  }
  if (!state.currentQR) {
    return res.send("Menunggu QR code tersedia...");
  }
  const qrImage = await QRCode.toDataURL(state.currentQR);
  res.send(`<html><body style="text-align:center;font-family:sans-serif"><h1>Scan QR WhatsApp</h1><img src="${qrImage}" style="width:90%;max-width:300px;border:10px solid #fff;box-shadow:0 0 10px #aaa;border-radius:8px;" /><p>Halaman ini auto-refresh tiap 15 detik</p><meta http-equiv="refresh" content="15" /></body></html>`);
});

app.get("/health", (req, res) => {
  res.json({
    status: state.isReady ? "healthy" : "initializing",
    whatsapp_ready: state.isReady,
    qr_available: !!state.currentQR,
    restart_count: state.restartCount,
    auto_rekap_enabled: state.autoRekapEnabled,
    cron_notifikasi_aktif: !!cronJobNotifikasi,
    cron_jadwal_berikutnya: cronJobNotifikasi ? formatCronNextRun(cronJobNotifikasi) : null,
    cron_reset_akun_aktif: !!cronJobResetAkun,
    cron_reset_akun_berikutnya: cronJobResetAkun ? formatCronNextRun(cronJobResetAkun) : null,
    reconnect_attempts: state.reconnectAttempts,
    wa_state: state.waState,
    is_reconnecting: state.isReconnecting
  });
});

// ==================== MAIN ====================
const startServer = async () => {
  try {
    initializeWhatsApp();
    app.listen(PORT, '0.0.0.0', () => console.log(`QR server di http://localhost:${PORT}`));
    console.log('Aplikasi berhasil dijalankan');
  } catch (error) {
    console.error('Gagal memulai server:', error);
    process.exit(1);
  }
};

process.on('unhandledRejection', (reason, promise) => {
  console.error('Unhandled Rejection at:', promise, 'reason:', reason);
});

process.on('uncaughtException', (error) => {
  console.error('Uncaught Exception:', error);
  setTimeout(() => {
    console.log('Restarting after uncaught exception...');
    scheduleReconnect();
  }, 5000);
});

startServer();