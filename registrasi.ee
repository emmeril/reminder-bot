// ==================== HELPER FUNCTIONS ====================
const getNamaBulan = (bulanAngka) => {
  const bulan = [
    "Januari", "Februari", "Maret", "April", "Mei", "Juni",
    "Juli", "Agustus", "September", "Oktober", "November", "Desember"
  ];
  return bulan[bulanAngka] || "Tidak Diketahui";
};

const formatDuration = (milliseconds) => {
  const totalSeconds = Math.floor(milliseconds / 1000);
  const seconds = totalSeconds % 60;
  const totalMinutes = Math.floor(totalSeconds / 60);
  const minutes = totalMinutes % 60;
  const hours = Math.floor(totalMinutes / 60);
  let formatted = "";
  if (hours > 0) formatted += `${hours} jam `;
  if (minutes > 0) formatted += `${minutes} menit `;
  if (seconds > 0 || formatted === "") formatted += `${seconds} detik`;
  return formatted.trim();
};

const generateRandomString = (length = 5) => {
  return Math.random().toString(36).substring(2, 2 + length);
};

const splitArgs = (args = "") => {
  const trimmed = args.trim();
  return trimmed ? trimmed.split(/\s+/) : [];
};

const parsePositiveInt = (rawValue, { min = 1, max = Number.MAX_SAFE_INTEGER } = {}) => {
  const value = Number.parseInt(String(rawValue ?? "").trim(), 10);
  if (!Number.isFinite(value) || value < min || value > max) {
    return null;
  }
  return value;
};

const pad2 = (value) => String(value).padStart(2, '0');

const formatPeriodeTanggal = ({ hari, bulan, tahun }) => `${pad2(hari)}-${pad2(bulan)}-${tahun}`;

const formatPeriodeBulanan = ({ bulan, tahun }) => `${pad2(bulan)}-${tahun}`;

const getHourInTimezone = (dateInput, timeZone = APP_TIMEZONE) => {
  const dateObj = new Date(dateInput);
  if (Number.isNaN(dateObj.getTime())) return null;
  const hourValue = new Intl.DateTimeFormat('en-GB', {
    timeZone,
    hour: '2-digit',
    hour12: false
  }).format(dateObj);
  const hour = Number(hourValue);
  return Number.isInteger(hour) ? hour : null;
};

const isValidDateValue = (hari, bulan, tahun) => {
  if (!Number.isInteger(hari) || !Number.isInteger(bulan) || !Number.isInteger(tahun)) return false;
  if (tahun < 1970 || tahun > 9999) return false;
  if (bulan < 1 || bulan > 12) return false;
  const lastDay = new Date(tahun, bulan, 0).getDate();
  return hari >= 1 && hari <= lastDay;
};

const getDatePartsInTimezone = (dateInput, timeZone = APP_TIMEZONE) => {
  const dateObj = new Date(dateInput);
  if (Number.isNaN(dateObj.getTime())) return null;
  const formatter = new Intl.DateTimeFormat('en-CA', {
    timeZone,
    day: '2-digit',
    month: '2-digit',
    year: 'numeric'
  });
  const parts = formatter.formatToParts(dateObj);
  const dayPart = parts.find((part) => part.type === 'day')?.value;
  const monthPart = parts.find((part) => part.type === 'month')?.value;
  const yearPart = parts.find((part) => part.type === 'year')?.value;
  const hari = Number(dayPart);
  const bulan = Number(monthPart);
  const tahun = Number(yearPart);
  if (!isValidDateValue(hari, bulan, tahun)) return null;
  return { hari, bulan, tahun };
};

const formatDateKeyInTimezone = (dateInput, timeZone = APP_TIMEZONE) => {
  const dateParts = getDatePartsInTimezone(dateInput, timeZone);
  if (!dateParts) return null;
  const { tahun, bulan, hari } = dateParts;
  return `${tahun}-${pad2(bulan)}-${pad2(hari)}`;
};

const parseDurationToMilliseconds = (duration) => {
  const normalized = String(duration || "").trim().toLowerCase();
  const match = normalized.match(/^(\d+)([mhd])$/);
  if (!match) return null;
  const amount = Number(match[1]);
  const unit = match[2];
  if (!Number.isInteger(amount) || amount <= 0) return null;
  if (unit === 'm') return amount * 60 * 1000;
  if (unit === 'h') return amount * 60 * 60 * 1000;
  if (unit === 'd') return amount * 24 * 60 * 60 * 1000;
  return null;
};

const inferDurationFromProfileName = (profileName) => {
  const normalized = String(profileName || "").trim().toLowerCase();
  if (!normalized) return null;

  // Pola: angka diikuti langsung oleh m/h/d (tanpa spasi) dan batas kata
  let match = normalized.match(/(\d+)([mhd])\b/);
  if (match) return `${Number(match[1])}${match[2]}`;

  // Pola: angka, spasi opsional, m/h/d, dengan batas kata sebelumnya
  match = normalized.match(/\b(\d+)\s*([mhd])\b/);
  if (match) return `${Number(match[1])}${match[2]}`;

  // Deteksi kata jam/j/hour/hours
  match = normalized.match(/(\d+)\s*[-_ ]?(jam|j|hour|hours)\b/);
  if (match) return `${Number(match[1])}h`;

  // Deteksi kata hari/day/days
  match = normalized.match(/(\d+)\s*[-_ ]?(hari|day|days)\b/);
  if (match) return `${Number(match[1])}d`;

  // Deteksi kata menit/min/mnt/minute/minutes
  match = normalized.match(/(\d+)\s*[-_ ]?(menit|min|mnt|minute|minutes)\b/);
  if (match) return `${Number(match[1])}m`;

  // Deteksi bulan (30 hari)
  match = normalized.match(/(\d+)\s*[-_ ]?(bulan|month|months)\b/);
  if (match) return `${Number(match[1]) * 30}d`;

  // Deteksi minggu (7 hari)
  match = normalized.match(/(\d+)\s*[-_ ]?(minggu|week|weeks)\b/);
  if (match) return `${Number(match[1]) * 7}d`;

  // Fallback terakhir: ambil angka di akhir nama (misal "free1") dan asumsikan jam
  match = normalized.match(/(\d+)$/);
  if (match) return `${Number(match[1])}h`;

  return null;
};

const getDurationValueForProfile = (profile, durasiProfile) => {
  const stored = durasiProfile?.[profile];
  if (parseDurationToMilliseconds(stored)) return stored;

  const inferred = inferDurationFromProfileName(profile);
  if (parseDurationToMilliseconds(inferred)) return inferred;

  return null;
};

const inferTanggalAktifFromExpired = (tanggalExpired, profile, durasiProfile) => {
  if (!tanggalExpired || !profile) return null;
  const expiredDate = new Date(tanggalExpired);
  if (Number.isNaN(expiredDate.getTime())) return null;
  const durationRaw = getDurationValueForProfile(profile, durasiProfile);
  const durationMs = parseDurationToMilliseconds(durationRaw);
  if (!durationMs) return null;
  return new Date(expiredDate.getTime() - durationMs).toISOString();
};

const getComparableHistoryTime = (entry) => {
  const expiredTs = entry?.tanggalExpired ? new Date(entry.tanggalExpired).getTime() : NaN;
  if (Number.isFinite(expiredTs)) return expiredTs;
  const aktifTs = entry?.tanggalAktif ? new Date(entry.tanggalAktif).getTime() : NaN;
  if (Number.isFinite(aktifTs)) return aktifTs;
  const dicatatTs = entry?.tanggalDicatat ? new Date(entry.tanggalDicatat).getTime() : NaN;
  if (Number.isFinite(dicatatTs)) return dicatatTs;
  return 0;
};

const buildLatestHistoryMapByName = (historyUsers = [], normalizeKey = false) => {
  const latestMap = new Map();
  historyUsers.forEach((entry) => {
    const rawName = String(entry?.name || "").trim();
    if (!rawName) return;
    const key = normalizeKey ? rawName.toLowerCase() : rawName;
    const current = latestMap.get(key);
    if (!current || getComparableHistoryTime(entry) > getComparableHistoryTime(current)) {
      latestMap.set(key, entry);
    }
  });
  return latestMap;
};

const resolveTanggalAktifState = (userData, existingEntry, durasiProfile, fallbackTimestamp) => {
  if (userData?.tanggalAktif) {
    return {
      tanggalAktif: userData.tanggalAktif,
      tanggalAktifSource: userData.tanggalAktifSource || existingEntry?.tanggalAktifSource || 'manual'
    };
  }

  if (existingEntry?.tanggalAktif && existingEntry?.tanggalAktifSource && existingEntry.tanggalAktifSource !== 'fallback') {
    return {
      tanggalAktif: existingEntry.tanggalAktif,
      tanggalAktifSource: existingEntry.tanggalAktifSource
    };
  }

  const inferred = inferTanggalAktifFromExpired(userData?.tanggalExpired, userData?.profile, durasiProfile);
  if (inferred) {
    return { tanggalAktif: inferred, tanggalAktifSource: 'calculated' };
  }

  return {
    tanggalAktif: existingEntry?.tanggalAktif || fallbackTimestamp,
    tanggalAktifSource: 'fallback'
  };
};

const resolveTanggalAktifForRekap = (user, durasiProfile) => {
  if (!user) return null;

  // Prioritaskan perhitungan ulang dari tanggal expired jika ada
  if (user.tanggalExpired) {
    const inferred = inferTanggalAktifFromExpired(user.tanggalExpired, user.profile, durasiProfile);
    if (inferred) return inferred;
  }

  // Fallback ke tanggal aktif yang tersimpan (jika tidak bisa dihitung ulang)
  if (user.tanggalAktif) return user.tanggalAktif;

  return null;
};

const parseCommandPayload = (fullCommand = "") => {
  const trimmed = fullCommand.trim();
  if (!trimmed || !trimmed.startsWith(COMMAND_PREFIX)) {
    return null;
  }
  const spaceIndex = trimmed.indexOf(" ");
  const command = (spaceIndex === -1 ? trimmed.slice(1) : trimmed.slice(1, spaceIndex)).toLowerCase();
  const args = spaceIndex === -1 ? "" : trimmed.slice(spaceIndex + 1).trim();
  return { command, args };
};

const parseRekapArgs = (args = "") => {
  const normalized = String(args || "").trim().toLowerCase();
  if (normalized === "harian") return { mode: "harian" };
  if (normalized === "bulanan") return { mode: "bulanan" };

  if (/^\d{1,2}-\d{1,2}-\d{4}$/.test(normalized)) {
    const [hari, bulan, tahun] = normalized.split("-").map(Number);
    if (!isValidDateValue(hari, bulan, tahun)) return null;
    return { mode: "spesifik", tanggal: formatPeriodeTanggal({ hari, bulan, tahun }) };
  }

  if (/^\d{1,2}-\d{4}$/.test(normalized)) {
    const [bulan, tahun] = normalized.split("-").map(Number);
    if (!Number.isInteger(bulan) || bulan < 1 || bulan > 12) return null;
    if (!Number.isInteger(tahun) || tahun < 1970 || tahun > 9999) return null;
    return { mode: "spesifik", bulan, tahun };
  }

  return null;
};

const formatUsernameFromNama = (nama) => {
  return nama.toLowerCase()
    .replace(/\s+/g, '_')
    .replace(/[^a-z0-9_]/g, '');
};

const buildHotspotEmailFromNomer = (nomer) => {
  const normalized = String(nomer || "").replace(/\D/g, "");
  if (!normalized) return "";
  return `${normalized}@localhost.local`;
};

const parseTanggalKomentar = (comment) => {
  if (!comment) return null;
  const regex1 = /(\w{3})\/(\d{1,2})\/(\d{4}) (\d{1,2}):(\d{2}):(\d{2})/i;
  const regex2 = /(\d{1,2})\/(\w{3})\/(\d{4}) (\d{1,2}):(\d{2}):(\d{2})/i;
  let match = comment.match(regex1);
  let format = 1;
  if (!match) {
    match = comment.match(regex2);
    format = 2;
  }
  if (!match) return null;
  try {
    const bulanMap = {
      'jan': 0, 'feb': 1, 'mar': 2, 'apr': 3, 'may': 4, 'jun': 5,
      'jul': 6, 'aug': 7, 'sep': 8, 'oct': 9, 'nov': 10, 'dec': 11
    };
    let bulan, hari, tahun, jam, menit, detik;
    if (format === 1) {
      bulan = bulanMap[match[1].toLowerCase()];
      hari = Number.parseInt(match[2], 10);
      tahun = Number.parseInt(match[3], 10);
    } else {
      hari = Number.parseInt(match[1], 10);
      bulan = bulanMap[match[2].toLowerCase()];
      tahun = Number.parseInt(match[3], 10);
    }
    jam = Number.parseInt(match[4], 10);
    menit = Number.parseInt(match[5], 10);
    detik = Number.parseInt(match[6], 10);
    if (!Number.isInteger(bulan)) return null;
    const parsedDate = new Date(tahun, bulan, hari, jam, menit, detik);
    if (Number.isNaN(parsedDate.getTime())) return null;
    return parsedDate;
  } catch (error) {
    console.error('Error parsing tanggal:', error);
    return null;
  }
};

const formatCronNextRun = (cronJob) => {
  try {
    if (!cronJob) return null;
    const nextRunRaw = cronJob.nextDate();
    if (nextRunRaw && typeof nextRunRaw.toJSDate === 'function') {
      return nextRunRaw.toJSDate().toLocaleString('id-ID', { timeZone: APP_TIMEZONE });
    }
    if (nextRunRaw instanceof Date) {
      return nextRunRaw.toLocaleString('id-ID', { timeZone: APP_TIMEZONE });
    }
    return String(nextRunRaw);
  } catch (error) {
    console.error('[Cron] Gagal format jadwal berikutnya:', error);
    return null;
  }
};

const dapatkanInfoTagihan = (profile, tanggalExpired) => {
  try {
    const hargaProfil = bacaHargaProfil();
    const harga = hargaProfil[profile];
    if (!harga) return null;
    const tanggal = new Date(tanggalExpired);
    const namaBulan = getNamaBulan(tanggal.getMonth());
    const tanggalFormat = tanggal.toLocaleDateString('id-ID');
    const hargaFormatted = harga.toLocaleString('id-ID');
    return { bulan: namaBulan, tanggal: tanggalFormat, harga, hargaFormatted };
  } catch (error) {
    console.error('Error mendapatkan info tagihan:', error);
    return null;
  }
};

// ==================== FILE I/O DENGAN CACHE ====================
const readJSON = (file, cacheKey, defaultData) => {
  const now = Date.now();
  const cache = state.cache[cacheKey];
  if (cache && cache.data !== null && (now - cache.timestamp) < CACHE_TTL) {
    return cache.data;
  }
  try {
    if (fs.existsSync(file)) {
      const data = JSON.parse(fs.readFileSync(file, 'utf8'));
      state.cache[cacheKey] = { data, timestamp: now };
      return data;
    }
  } catch (error) {
    console.error(`Error membaca ${file}:`, error);
  }
  state.cache[cacheKey] = { data: defaultData, timestamp: now };
  return defaultData;
};

const writeJSON = (file, cacheKey, data) => {
  try {
    fs.writeFileSync(file, JSON.stringify(data, null, 2));
    state.cache[cacheKey] = { data, timestamp: Date.now() };
    return true;
  } catch (error) {
    console.error(`Error menyimpan ${file}:`, error);
    return false;
  }
};

const bacaAdminList = () => readJSON(ADMIN_FILE, 'adminList', adminNumber ? [adminNumber] : []);
const simpanAdminList = (data) => writeJSON(ADMIN_FILE, 'adminList', data);
const bacaHargaProfil = () => readJSON(HARGA_FILE, 'hargaProfil', {});
const simpanHargaProfil = (data) => writeJSON(HARGA_FILE, 'hargaProfil', data);
const bacaDurasiProfile = () => readJSON(DURASI_PROFILE_FILE, 'durasiProfile', {});
const simpanDurasiProfile = (data) => writeJSON(DURASI_PROFILE_FILE, 'durasiProfile', data);
const bacaRekapPendapatan = () => readJSON(REKAP_FILE, 'rekap', {});
const simpanRekapPendapatan = (data) => writeJSON(REKAP_FILE, 'rekap', data);
const bacaAutoRekapSetting = () => readJSON(AUTO_REKAP_FILE, 'autoRekap', { enabled: false, interval: 1 });
const simpanAutoRekapSetting = (data) => writeJSON(AUTO_REKAP_FILE, 'autoRekap', data);
const bacaHistoryUser = () => readJSON(HISTORY_FILE, 'history', []);
const simpanHistoryUser = (data) => writeJSON(HISTORY_FILE, 'history', data);
const bacaPelanggan = () => readJSON(PELANGGAN_FILE, 'pelanggan', []);
const simpanPelanggan = (data) => writeJSON(PELANGGAN_FILE, 'pelanggan', data);
const bacaRiwayatInfo = () => readJSON(INFO_FILE, 'info', []);
const simpanRiwayatInfo = (data) => writeJSON(INFO_FILE, 'info', data);

// ==================== HISTORY MANAGEMENT ====================
const upsertHistoryUsers = (entries, existingHistory = null) => {
  const history = Array.isArray(existingHistory) ? existingHistory : bacaHistoryUser();
  const durasiProfile = bacaDurasiProfile();
  const buildTransactionKey = (user) => {
    const name = String(user?.name || "").trim();
    if (!name) return null;
    const expired = user?.tanggalExpired ? new Date(user.tanggalExpired) : null;
    if (expired && !Number.isNaN(expired.getTime())) {
      return `${name}__${expired.toISOString()}`;
    }
    return null;
  };

  const transactionToIndex = new Map();
  history.forEach((user, index) => {
    const key = buildTransactionKey(user);
    if (key) transactionToIndex.set(key, index);
  });

  let inserted = 0;
  let updated = 0;

  entries.forEach((userData) => {
    if (!userData?.name) return;
    const transactionKey = buildTransactionKey(userData);

    if (transactionKey && transactionToIndex.has(transactionKey)) {
      const index = transactionToIndex.get(transactionKey);
      const oldTanggalDicatat = history[index].tanggalDicatat || new Date().toISOString();
      const aktifState = resolveTanggalAktifState(userData, history[index], durasiProfile, oldTanggalDicatat);
      history[index] = { ...history[index], ...userData, ...aktifState, tanggalDicatat: oldTanggalDicatat };
      updated++;
      return;
    }

    if (!transactionKey) {
      const fallbackIndex = history.findIndex((item) => item?.name === userData.name && !item?.tanggalExpired);
      if (fallbackIndex !== -1) {
        const oldTanggalDicatat = history[fallbackIndex].tanggalDicatat || new Date().toISOString();
        const aktifState = resolveTanggalAktifState(userData, history[fallbackIndex], durasiProfile, oldTanggalDicatat);
        history[fallbackIndex] = { ...history[fallbackIndex], ...userData, ...aktifState, tanggalDicatat: oldTanggalDicatat };
        updated++;
        return;
      }
    }

    const tanggalDicatat = new Date().toISOString();
    const aktifState = resolveTanggalAktifState(userData, null, durasiProfile, tanggalDicatat);
    history.push({ ...userData, ...aktifState, tanggalDicatat });
    if (transactionKey) {
      transactionToIndex.set(transactionKey, history.length - 1);
    }
    inserted++;
  });

  return { history, inserted, updated, changed: inserted > 0 || updated > 0 };
};

const tambahKeHistory = (userData) => {
  const { history, inserted, updated, changed } = upsertHistoryUsers([userData]);
  if (!changed) return true;
  if (inserted > 0) {
    console.log(`[History] Tambah data baru untuk ${userData.name}`);
  } else if (updated > 0) {
    console.log(`[History] Update data untuk ${userData.name}`);
  }
  return simpanHistoryUser(history);
};

// ==================== MIKROTIK CONNECTION ====================
const tryConnectToMikrotik = async (config, label) => {
  try {
    console.log(`[INFO] Mencoba koneksi ke MikroTik ${label}`);
    const client = new RouterOSClient(config);
    const connection = await client.connect();
    await connection.menu("/system/identity").getOnly();
    console.log(`[SUCCESS] Terhubung ke MikroTik ${label}`);
    return { client, connection };
  } catch (error) {
    console.warn(`[WARN] Gagal terhubung ke MikroTik ${label}: ${error.message}`);
    return null;
  }
};

const connectToMikrotikWithRetry = async (retryCount = 0) => {
  let result = await tryConnectToMikrotik(mikrotikConfigs.primary, "primary");
  if (!result) {
    result = await tryConnectToMikrotik(mikrotikConfigs.backup, "backup");
  }
  if (!result) {
    if (retryCount < 5) {
      const delay = Math.pow(2, retryCount) * 1000;
      console.error(`[ERROR] Gagal terhubung. Mencoba lagi dalam ${delay / 1000} detik...`);
      await new Promise(resolve => setTimeout(resolve, delay));
      return connectToMikrotikWithRetry(retryCount + 1);
    } else {
      console.error("[FATAL] Gagal terhubung ke kedua MikroTik setelah beberapa percobaan.");
      return null;
    }
  }
  return result;
};

const executeWithMikrotik = async (operation, errorMessage = "Terjadi kesalahan") => {
  let connectionObj = null;
  try {
    connectionObj = await connectToMikrotikWithRetry();
    if (!connectionObj) throw new Error("Gagal terhubung ke MikroTik");
    const result = await operation(connectionObj.connection);
    return result;
  } catch (error) {
    console.error(`${errorMessage}:`, error);
    throw error;
  } finally {
    if (connectionObj && connectionObj.client) {
      connectionObj.client.close();
      console.log("Koneksi MikroTik ditutup.");
    }
  }
};

// ==================== MIKROTIK OPERATIONS ====================
const mikrotikOperations = {
  async getActiveHotspotUsers(chatId) {
    return executeWithMikrotik(async (conn) => {
      const activeUsers = await conn.menu("/ip/hotspot/active").print();
      if (!activeUsers || activeUsers.length === 0) {
        return client.sendMessage(chatId, "Tidak ada user hotspot aktif.");
      }
      let message = `*User Hotspot Aktif (${activeUsers.length} User):*\n\n`;
      activeUsers.forEach(user => {
        message += `*User:* ${user.user}\n`;
        message += `*Address:* ${user.address}\n`;
        message += `*MAC Address:* ${user["mac-address"] || "-"}\n`;
        message += `*Comment:* ${user.comment || "-"}\n`;
        message += "---\n";
      });
      await client.sendMessage(chatId, message);
    }, "Gagal mengambil data user aktif");
  },

  async getNetwatchStatus(chatId, manualFetch = false) {
    return executeWithMikrotik(async (conn) => {
      const netwatchData = await conn.menu("/tool/netwatch").print();
      const currentNetwatchStatus = {};
      const now = new Date();
      if (!netwatchData || netwatchData.length === 0) {
        if (manualFetch) await client.sendMessage(chatId, "Tidak ada entri Netwatch.");
        return;
      }
      let upCount = 0, downCount = 0;
      const upApList = [], downApList = [];
      netwatchData.forEach(entry => {
        currentNetwatchStatus[entry.host] = entry.status;
        if (entry.status === "up") {
          upCount++;
          upApList.push({ host: entry.host, comment: entry.comment || "-" });
        } else if (entry.status === "down") {
          downCount++;
          downApList.push({ host: entry.host, comment: entry.comment || "-" });
          if (state.previousNetwatchStatus[entry.host] === "up") {
            state.apDownSince[entry.host] = now;
          }
        }
      });
      // Hitung durasi down yang sudah pulih
      for (const host in state.previousNetwatchStatus) {
        if (state.previousNetwatchStatus[host] === "down" && currentNetwatchStatus[host] === "up" && state.apDownSince[host]) {
          delete state.apDownSince[host];
        }
      }
      if (manualFetch) {
        let message = `*Status Netwatch AP (${netwatchData.length} AP):*\n\n`;
        message += `*AP Up:* ${upCount}\n*AP Down:* ${downCount}\n\n`;
        if (upCount > 0) {
          message += `*AP Yang Up:*\n`;
          upApList.forEach(ap => {
            message += `*Host:* ${ap.host}\n${ap.comment ? `*Comment:* ${ap.comment}\n` : ''}\n`;
          });
        }
        if (downCount > 0) {
          message += `*AP Yang Down:*\n`;
          downApList.forEach(ap => {
            message += `*Host:* ${ap.host}\n${ap.comment ? `*Comment:* ${ap.comment}\n` : ''}\n`;
          });
        }
        await client.sendMessage(chatId, message);
      }
      state.previousNetwatchStatus = currentNetwatchStatus;
    }, "Gagal mengambil status Netwatch");
  },

  async getTotalUserProfileCounts(chatId) {
    return executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      if (!users || users.length === 0) {
        return client.sendMessage(chatId, "Tidak ada user hotspot.");
      }
      const profileCounts = {};
      users.forEach(user => profileCounts[user.profile] = (profileCounts[user.profile] || 0) + 1);
      let message = "*Jumlah User Hotspot per Profile:*\n\n";
      for (const profile in profileCounts) {
        message += `*Profile:* ${profile}\n*Total User:* ${profileCounts[profile]}\n\n`;
      }
      await client.sendMessage(chatId, message);
    }, "Gagal mengambil jumlah user per profile");
  },

  async findUserByName(chatId, searchTerm) {
    return executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      if (!users || users.length === 0) {
        return client.sendMessage(chatId, "Tidak ada user hotspot.");
      }
      const searchResults = users.filter(user => user.name && user.name.toLowerCase().includes(searchTerm.toLowerCase()));
      if (searchResults.length === 0) {
        return client.sendMessage(chatId, `Tidak ditemukan user dengan nama "${searchTerm}".`);
      }
      let message = `*Hasil Pencarian "${searchTerm}" (${searchResults.length} User):*\n\n`;
      searchResults.forEach(user => {
        message += `*Nama:* ${user.name}\n*Password:* ${user.password || "-"}\n*Comment:* ${user.comment || "-"}\n*Profile:* ${user.profile || "-"}\n---\n`;
      });
      await client.sendMessage(chatId, message);
    }, "Gagal mencari user");
  },

  async getHotspotProfiles(chatId) {
    return executeWithMikrotik(async (conn) => {
      const profiles = await conn.menu("/ip/hotspot/user/profile").print();
      if (!profiles || profiles.length === 0) {
        return client.sendMessage(chatId, "Tidak ada profile hotspot.");
      }
      const hargaProfil = bacaHargaProfil();
      const durasiProfile = bacaDurasiProfile();
      let message = "*Profile Hotspot yang Tersedia:*\n\n";
      profiles.forEach(profile => {
        const harga = hargaProfil[profile.name] ? `- Rp ${hargaProfil[profile.name].toLocaleString('id-ID')}` : '';
        const durasi = durasiProfile[profile.name] ? `- ${durasiProfile[profile.name]}` : '';
        const rateLimit = profile['rate-limit'] ? `- Limit: ${profile['rate-limit']}` : '';
        message += `- ${profile.name} ${harga} ${durasi} ${rateLimit}\n`;
      });
      message += `\nUsage: \`#adduser <username> <password> <profile>\``;
      await client.sendMessage(chatId, message);
    }, "Gagal mengambil profile hotspot");
  },

  async addUserToHotspot(chatId, username, password, profile) {
    return executeWithMikrotik(async (conn) => {
      const addResult = await conn.menu("/ip/hotspot/user").add({ name: username, password, profile });
      if (addResult && !addResult["!trap"]) {
        await client.sendMessage(chatId, `User "${username}" berhasil ditambahkan dengan profile "${profile}".`);
      } else {
        const errorMsg = addResult?.["!trap"]?.[0]?.message || "Error tidak diketahui";
        await client.sendMessage(chatId, `Gagal menambahkan user "${username}": ${errorMsg}`);
      }
    }, "Gagal menambahkan user");
  },

  async generateBulkUsers(chatId, profileName, count, usernamePrefix = "") {
    return executeWithMikrotik(async (conn) => {
      const randomBatchId = Math.floor(Math.random() * 1000).toString().padStart(3, "0");
      const now = new Date();
      const day = String(now.getDate()).padStart(2, "0");
      const month = String(now.getMonth() + 1).padStart(2, "0");
      const year = String(now.getFullYear()).slice(-2);
      const commentTemplate = `up-${randomBatchId}-${month}.${day}.${year}-${profileName}`;

      let successCount = 0, errorCount = 0;
      const errors = [], successUsers = [];

      for (let i = 1; i <= count; i++) {
        const randomUsername = usernamePrefix + generateRandomString();
        const randomPassword = generateRandomString();
        try {
          const addResult = await conn.menu("/ip/hotspot/user").add({
            name: randomUsername,
            password: randomPassword,
            profile: profileName,
            comment: commentTemplate,
          });
          if (addResult && !addResult["!trap"]) {
            successCount++;
            successUsers.push({ username: randomUsername, password: randomPassword });
          } else {
            errorCount++;
            errors.push(`Error menambah user ${randomUsername}: ${addResult?.["!trap"]?.[0]?.message || "Unknown"}`);
          }
        } catch (error) {
          errorCount++;
          errors.push(`Exception menambah user ${randomUsername}: ${error.message}`);
        }
        await new Promise(resolve => setTimeout(resolve, 100));
      }

      if (successCount > 0) {
        try {
          const filepath = await buatFileExcelGenerate(successUsers, profileName, successCount, usernamePrefix);
          const media = MessageMedia.fromFilePath(filepath);
          await client.sendMessage(chatId, media, {
            caption: `*HASIL GENERATE USER - ${profileName}*\n\n` +
              `Berhasil: ${successCount} user\nGagal: ${errorCount} user\n` +
              `Profile: ${profileName}\nPrefix: ${usernamePrefix || 'Tidak ada'}\n` +
              `Template: ${commentTemplate}\n\n*File berisi daftar username dan password.*`
          });
          setTimeout(() => fs.unlink(filepath, (err) => err && console.error('Gagal hapus file Excel:', err)), 30000);
        } catch (error) {
          console.error('Error membuat file Excel generate:', error);
          let message = `*Ringkasan Pembuatan User:*\n\nBerhasil: ${successCount} user dengan template '${commentTemplate}'\nGagal: ${errorCount} user\n\n`;
          if (errorCount > 0) {
            message += `*Kesalahan:*\n${errors.slice(0, 10).map(e => `- ${e}`).join('\n')}`;
            if (errors.length > 10) message += `\nLihat log server untuk semua kesalahan.`;
          }
          await client.sendMessage(chatId, message);
        }
      } else {
        let message = `*Gagal Membuat User:*\n\nTidak ada user yang berhasil dibuat\nProfile: ${profileName}\nPrefix: ${usernamePrefix || 'Tidak ada'}\n\n`;
        if (errorCount > 0) {
          message += `*Kesalahan:*\n${errors.slice(0, 5).map(e => `- ${e}`).join('\n')}`;
        }
        await client.sendMessage(chatId, message);
      }
    }, "Gagal membuat user secara massal");
  },

  async addHotspotProfile(chatId, profileName, duration, rxLimit = null, txLimit = null, lockMode = "lock") {
    return executeWithMikrotik(async (conn) => {
      const profileScriptLock = `:put (",remc,667,${duration},1000,,Enable,"); {:local comment [ /ip hotspot user get [/ip hotspot user find where name="$user"] comment]; :local ucode [:pick $comment 0 2]; :if ($ucode = "vc" or $ucode = "up" or $comment = "") do={ :local date [ /system clock get date ];:local year [ :pick $date 7 11 ];:local month [ :pick $date 0 3 ]; /sys sch add name="$user" disable=no start-date=$date interval="${duration}"; :delay 5s; :local exp [ /sys sch get [ /sys sch find where name="$user" ] next-run]; :local getxp [len $exp]; :if ($getxp = 15) do={ :local d [:pick $exp 0 6]; :local t [:pick $exp 7 16]; :local s ("/"); :local exp ("$d$s$year $t"); /ip hotspot user set comment="$exp" [find where name="$user"];}; :if ($getxp = 8) do={ /ip hotspot user set comment="$date $exp" [find where name="$user"];}; :if ($getxp > 15) do={ /ip hotspot user set comment="$exp" [find where name="$user"];};:delay 5s; /sys sch remove [find where name="$user"]; :local mac $"mac-address"; :local time [/system clock get time ]; /system script add name="$date-|-$time-|-$user-|-667-|-$address-|-$mac-|-${duration}-|-${profileName}-|-$comment" owner="$month$year" source="$date" comment="mikhmon"; [:local mac $"mac-address"; /ip hotspot user set mac-address=$mac [find where name=$user]]}}`;
      const profileScriptUnlock = `:put (",remc,100000,${duration},100000,,Disable,"); {:local comment [ /ip hotspot user get [/ip hotspot user find where name="$user"] comment]; :local ucode [:pick $comment 0 2]; :if ($ucode = "vc" or $ucode = "up" or $comment = "") do={ :local date [ /system clock get date ];:local year [ :pick $date 7 11 ];:local month [ :pick $date 0 3 ]; /sys sch add name="$user" disable=no start-date=$date interval="${duration}"; :delay 5s; :local exp [ /sys sch get [ /sys sch find where name="$user" ] next-run]; :local getxp [len $exp]; :if ($getxp = 15) do={ :local d [:pick $exp 0 6]; :local t [:pick $exp 7 16]; :local s ("/"); :local exp ("$d$s$year $t"); /ip hotspot user set comment="$exp" [find where name="$user"];}; :if ($getxp = 8) do={ /ip hotspot user set comment="$date $exp" [find where name="$user"];}; :if ($getxp > 15) do={ /ip hotspot user set comment="$exp" [find where name="$user"];};:delay 5s; /sys sch remove [find where name="$user"]; :local mac $"mac-address"; :local time [/system clock get time ]; /system script add name="$date-|-$time-|-$user-|-100000-|-$address-|-$mac-|-${duration}-|-${profileName}-|-$comment" owner="$month$year" source="$date" comment="mikhmon"}}`;
      const profileScript = lockMode === "lock" ? profileScriptLock : profileScriptUnlock;
      const profileData = { name: profileName, "on-login": profileScript };
      if (rxLimit && txLimit) profileData['rate-limit'] = `${rxLimit}/${txLimit}`;
      const addResult = await conn.menu("/ip/hotspot/user/profile").add(profileData);
      if (addResult && !addResult["!trap"]) {
        const durasiProfile = bacaDurasiProfile();
        durasiProfile[profileName] = duration;
        simpanDurasiProfile(durasiProfile);
        await this.ensureMonitorScheduler(conn);
        let successMessage = `Profil "${profileName}" berhasil dibuat dengan durasi ${duration}.`;
        if (rxLimit && txLimit) successMessage += `\nLimit: ${rxLimit} download / ${txLimit} upload`;
        successMessage += `\nMAC Address: ${lockMode === "lock" ? 'LOCK' : 'UNLOCK'}`;
        await client.sendMessage(chatId, successMessage);
      } else {
        const errorMsg = addResult?.["!trap"]?.[0]?.message || "Error tidak diketahui";
        await client.sendMessage(chatId, `Gagal membuat profil "${profileName}": ${errorMsg}`);
      }
    }, "Gagal membuat profil hotspot");
  },

  async ensureMonitorScheduler(conn) {
    try {
      const existingSchedulers = await conn.menu("/system/scheduler").print();
      const monitorExists = existingSchedulers.some(s => s.name === "monitor");
      if (!monitorExists) {
        const monitorScript = `# Fungsi untuk mengonversi tanggal ke format YYYYMMDD
:local dateint do={ :local montharray {"jan";"feb";"mar";"apr";"may";"jun";"jul";"aug";"sep";"oct";"nov";"dec"}; :local days [:pick $d 4 6]; :local month [:pick $d 0 3]; :local year [:pick $d 7 11]; :local monthint ([:find $montharray $month] + 1); :if ([:len $monthint] = 1) do={ :set monthint ("0" . $monthint); } :return [:tonum ("$year$monthint$days")]; };
:local timeint do={ :local hours [:pick $t 0 2]; :local minutes [:pick $t 3 5]; :return ($hours * 60 + $minutes); };
:local date [/system clock get date]; :local time [/system clock get time]; :local today [$dateint d=$date]; :local curtime [$timeint t=$time];
:foreach i in=[/ip hotspot user find] do={ :local comment [/ip hotspot user get $i comment]; :local name [/ip hotspot user get $i name]; :if (([:pick $comment 3] = "/") and ([:pick $comment 6] = "/")) do={ :local expd [$dateint d=$comment]; :local expt [$timeint t=[:pick $comment 12 17]]; :if (($expd < $today) or ($expd = $today and $expt <= $curtime)) do={ /ip hotspot user remove $i; /ip hotspot active remove [find where user=$name]; } } }`;
        await conn.menu("/system/script").add({ name: "monitor", source: monitorScript });
        await conn.menu("/system/scheduler").add({ name: "monitor", interval: "00:01:00", onEvent: "/system script run monitor" });
        console.log("Scheduler monitor berhasil dibuat.");
      } else {
        console.log("Scheduler monitor sudah ada.");
      }
    } catch (error) {
      console.error("Error ensuring monitor scheduler:", error);
    }
  },

  async setHargaProfil(chatId, profileName, harga) {
    const hargaProfil = bacaHargaProfil();
    const hargaValue = Number.parseInt(String(harga), 10);
    hargaProfil[profileName] = hargaValue;
    if (simpanHargaProfil(hargaProfil)) {
      await client.sendMessage(chatId, `Harga profil "${profileName}" berhasil disetel: Rp ${hargaValue.toLocaleString('id-ID')}`);
    } else {
      await client.sendMessage(chatId, `Gagal menyimpan harga profil "${profileName}"`);
    }
  },

  async backupUserHistory(chatId) {
    return executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      const historyCandidates = [];
      if (users && users.length > 0) {
        users.forEach(user => {
          const expiredDate = parseExpiredDateFromComment(user.comment);
          if (expiredDate) {
            historyCandidates.push({
              name: user.name,
              profile: user.profile,
              comment: user.comment,
              tanggalExpired: expiredDate.toISOString(),
              password: user.password || '',
            });
          }
        });
      }

      if (historyCandidates.length === 0) {
        console.log("[Backup] Tidak ada data valid untuk dibackup.");
        return { changed: false, inserted: 0, updated: 0, reason: 'no_valid_data' };
      }

      const { history, inserted, updated, changed } = upsertHistoryUsers(historyCandidates);
      if (changed && simpanHistoryUser(history)) {
        console.log(`[Backup] ${inserted} user baru, ${updated} user diupdate.`);
        return { changed: true, inserted, updated, reason: 'saved' };
      }
      if (changed) {
        return { changed: true, inserted, updated, reason: 'save_failed' };
      }
      return { changed: false, inserted, updated, reason: 'no_changes' };
    }, "Gagal melakukan backup history");
  },

  async getRekapPendapatan(chatId, options = {}) {
    const { mode = 'bulanan', tanggal = null, bulan = null, tahun = null, isAutoCheck = false } = options;
    try {
      const result = prosesRekapDariHistory({ mode, tanggal, bulan, tahun, isAutoCheck });
      if (result.error) {
        if (!isAutoCheck) await client.sendMessage(chatId, result.error);
        return;
      }
      const rekapData = result.data;
      if (isAutoCheck) {
        let message = `*REKAP AUTO CHECK - ${new Date().toLocaleString('id-ID')}*\n\n`;
        const keys = Object.keys(rekapData);
        if (keys.length === 0) {
          console.log(`[AutoRekap] Tidak ada data untuk periode ini.`);
          return;
        }
        if (state.lastRekapData) {
          const currentTotal = Object.values(rekapData).reduce((sum, d) => sum + d.totalPendapatan, 0);
          const previousTotal = Object.values(state.lastRekapData).reduce((sum, d) => sum + d.totalPendapatan, 0);
          if (currentTotal === previousTotal) {
            console.log(`[AutoRekap] Tidak ada perubahan dalam pendapatan.`);
            return;
          }
        }
        keys.forEach(key => {
          const data = rekapData[key];
          message += `*Periode:* ${data.periode}\nTotal User: ${data.totalUser}\nTotal Pendapatan: Rp ${data.totalPendapatan.toLocaleString('id-ID')}\n\n`;
        });
        state.lastRekapData = rekapData;
        await client.sendMessage(chatId, message);
        return;
      }
      if (Object.keys(rekapData).length === 0) {
        return client.sendMessage(chatId, "Tidak ada data rekap untuk periode yang diminta.");
      }
      try {
        const jenisRekap = mode;
        const periode = Object.values(rekapData)[0].periode;
        const filepath = await buatFileExcel(rekapData, jenisRekap, periode);
        const media = MessageMedia.fromFilePath(filepath);
        await client.sendMessage(chatId, media, {
          caption: `*REKAP ${jenisRekap.toUpperCase()} BERDASARKAN TANGGAL AKTIF*\n` +
            `Periode: ${periode}\n` +
            `Total Pendapatan: Rp ${Object.values(rekapData)[0].totalPendapatan.toLocaleString('id-ID')}\n`
        });
        setTimeout(() => fs.unlink(filepath, (err) => err && console.error('Gagal hapus file Excel:', err)), 30000);
      } catch (error) {
        console.error('Error membuat file Excel:', error);
        await client.sendMessage(chatId, "Gagal membuat file Excel. Silakan coba lagi.");
      }
    } catch (error) {
      console.error('Error dalam getRekapPendapatan:', error);
      if (!isAutoCheck) await client.sendMessage(chatId, "Terjadi kesalahan saat mengambil rekap dari history.");
    }
  },

  async getDaftarHarga(chatId) {
    const hargaProfil = bacaHargaProfil();
    if (Object.keys(hargaProfil).length === 0) {
      return client.sendMessage(chatId, "Belum ada harga profil yang disetel. Gunakan `#setharga <profile> <harga>` untuk menambahkan.");
    }
    let message = `*DAFTAR HARGA PROFILE HOTSPOT*\n\n`;
    for (const [profile, harga] of Object.entries(hargaProfil)) {
      message += `*${profile}*: Rp ${harga.toLocaleString('id-ID')}\n`;
    }
    message += `\nGunakan \`#setharga <profile> <harga>\` untuk mengubah harga.`;
    await client.sendMessage(chatId, message);
  },

  async setAutoRekap(chatId, enabled, intervalMenit = 1) {
    const setting = { enabled, interval: intervalMenit };
    if (simpanAutoRekapSetting(setting)) {
      state.autoRekapEnabled = enabled;
      if (enabled) {
        startAutoRekapInterval(chatId, intervalMenit);
        await client.sendMessage(chatId, `Auto rekap diaktifkan. Akan berjalan setiap ${intervalMenit} menit.`);
      } else {
        if (state.autoRekapInterval) {
          clearInterval(state.autoRekapInterval);
          state.autoRekapInterval = null;
        }
        await client.sendMessage(chatId, "Auto rekap dimatikan.");
      }
    } else {
      await client.sendMessage(chatId, "Gagal menyimpan setting auto rekap.");
    }
  },

  async getStatusAutoRekap(chatId) {
    const setting = bacaAutoRekapSetting();
    let message = `*STATUS AUTO REKAP*\n\nStatus: ${setting.enabled ? 'AKTIF' : 'NONAKTIF'}\n`;
    if (setting.enabled) {
      message += `Interval: ${setting.interval} menit\nBerjalan: ${state.autoRekapEnabled ? 'Ya' : 'Tidak'}\n`;
    }
    message += `\nGunakan \`#autorekap on [menit]\` untuk mengaktifkan\nGunakan \`#autorekap off\` untuk menonaktifkan`;
    await client.sendMessage(chatId, message);
  },

  async addAdmin(chatId, phoneNumber) {
    const formattedNumber = phoneNumber.replace(/\D/g, '');
    if (tambahAdmin(formattedNumber)) {
      await client.sendMessage(chatId, `Nomor ${formattedNumber} berhasil ditambahkan sebagai admin.`);
    } else {
      await client.sendMessage(chatId, `Gagal menambahkan nomor ${formattedNumber} sebagai admin.`);
    }
  },

  async removeAdmin(chatId, phoneNumber) {
    const formattedNumber = phoneNumber.replace(/\D/g, '');
    if (hapusAdmin(formattedNumber)) {
      await client.sendMessage(chatId, `Nomor ${formattedNumber} berhasil dihapus dari daftar admin.`);
    } else {
      await client.sendMessage(chatId, `Nomor ${formattedNumber} tidak ditemukan dalam daftar admin.`);
    }
  },

  async getAdminList(chatId) {
    const adminList = bacaAdminList();
    if (adminList.length === 0) {
      return client.sendMessage(chatId, "Tidak ada admin yang terdaftar.");
    }
    let message = `*DAFTAR ADMIN*\n\n`;
    adminList.forEach((admin, index) => message += `${index + 1}. ${admin}\n`);
    message += `\nTotal: ${adminList.length} admin`;
    await client.sendMessage(chatId, message);
  },

  // ==================== ADD PELANGGAN DENGAN EMAIL ====================
  async addPelanggan(chatId, nama, nomer, profile) {
    const formattedNomer = nomer.replace(/\D/g, '');
    if (!formattedNomer.startsWith('62')) {
      return client.sendMessage(chatId, `Format nomor harus diawali 62 (contoh: 6281234567890)`);
    }
    const username = formatUsernameFromNama(nama);
    const password = formattedNomer.slice(-5);
    return executeWithMikrotik(async (conn) => {
      const users = await conn.menu("/ip/hotspot/user").print();
      const userExists = users.some(user => user.name === username);
      if (userExists) {
        return client.sendMessage(chatId, `Username "${username}" sudah ada di MikroTik.`);
      }
      // Simpan nomor di email dengan format email palsu
      const email = buildHotspotEmailFromNomer(formattedNomer);
      const addResult = await conn.menu("/ip/hotspot/user").add({
        name: username,
        password,
        profile,
        email: email,
        //comment: `Pelanggan: ${nama}` 
      });
      if (addResult && !addResult["!trap"]) {
        const success = tambahPelangganDanAkun({ username, nama, nomer: formattedNomer, profile, password });
        if (success) {
          tambahKeHistory({ name: username, profile, password, comment: `Pelanggan: ${nama} | Nomer: ${formattedNomer}` });
          const pesanAkunBaru = `Yth. Bapak/Ibu *${nama}*,\n\nAkun hotspot Anda sudah berhasil dibuat.\n\nDetail Akun Hotspot:\n*Username:* ${username}\n*Password:* ${password}\n*Profile:* ${profile}\n\nSilakan simpan data ini. Terimakasih.`;
          try {
            await client.sendMessage(`${formattedNomer}@c.us`, pesanAkunBaru);
          } catch (sendErr) {
            console.error(`[AddPelanggan] Gagal kirim kredensial ke ${formattedNomer}:`, sendErr.message);
            await client.sendMessage(chatId, `Pelanggan berhasil dibuat, tetapi pengiriman username/password ke ${formattedNomer} gagal.`);
          }
          await client.sendMessage(chatId,
            `Pelanggan berhasil ditambahkan dan akun dibuat:\n\nNama: ${nama}\nNomor: ${formattedNomer}\nUsername: ${username}\nPassword: ${password}\nProfile: ${profile}\n\nNotifikasi akan dikirim jam 8 pagi sebelum expired.`
          );
        } else {
          let rollbackMessage = "Akun hotspot yang sempat dibuat sudah dicoba rollback.";
          try {
            const rollbackResult = await removeHotspotUsersByName(conn, username);
            if (rollbackResult.remaining > 0) {
              rollbackMessage = `Akun hotspot gagal dihapus penuh. Masih tersisa ${rollbackResult.remaining} user bernama ${username}.`;
            }
          } catch (rollbackError) {
            console.error(`[AddPelanggan] Rollback gagal untuk ${username}:`, rollbackError);
            rollbackMessage = "Rollback akun hotspot gagal. Perlu pengecekan manual di MikroTik.";
          }
          await client.sendMessage(chatId, `Gagal menyimpan data pelanggan lokal. ${rollbackMessage}`);
        }
      } else {
        const errorMsg = addResult?.["!trap"]?.[0]?.message || "Error tidak diketahui";
        await client.sendMessage(chatId, `Gagal membuat akun untuk "${username}": ${errorMsg}`);
      }
    }, "Gagal membuat akun pelanggan");
  },

  async getDaftarPelanggan(chatId) {
    const pelangganList = bacaPelanggan();
    if (pelangganList.length === 0) {
      return client.sendMessage(chatId, "Belum ada pelanggan yang terdaftar.");
    }
    const historyUsers = bacaHistoryUser();
    const historyByUsername = buildLatestHistoryMapByName(historyUsers, true);
    let message = `*DAFTAR PELANGGAN*\n\n`;
    for (const pelanggan of pelangganList) {
      let expiredInfo = '(Belum ada data expired)';
      const userHistory = pelanggan.username ? historyByUsername.get(pelanggan.username.toLowerCase()) : null;
      if (userHistory && userHistory.tanggalExpired) {
        try {
          const expiredDate = new Date(userHistory.tanggalExpired);
          expiredInfo = `(Exp: ${expiredDate.toLocaleDateString('id-ID')} ${expiredDate.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })})`;
        } catch (e) { expiredInfo = '(Format tanggal expired tidak valid)'; }
      } else if (userHistory && userHistory.comment) {
        const parsedDate = parseTanggalKomentar(userHistory.comment);
        if (parsedDate) {
          expiredInfo = `(Exp: ${parsedDate.toLocaleDateString('id-ID')} ${parsedDate.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })})`;
        }
      }
      let tagihanInfo = '';
      if (userHistory && userHistory.tanggalExpired) {
        const infoTagihan = dapatkanInfoTagihan(pelanggan.profile, userHistory.tanggalExpired);
        if (infoTagihan) tagihanInfo = `\nTagihan: Rp ${infoTagihan.hargaFormatted} (${infoTagihan.bulan})`;
      }
      message += `*${pelanggan.nama}*\n${pelanggan.nomer}\nUser: ${pelanggan.username}\nPass: ${pelanggan.password || 'tidak ada'}\nProfile: ${pelanggan.profile || 'tidak ada'}\nDaftar: ${new Date(pelanggan.tanggalDaftar || pelanggan.tanggalUpdate).toLocaleDateString('id-ID')}\nStatus: ${expiredInfo}${tagihanInfo}\n---\n`;
    }
    message += `\nTotal: ${pelangganList.length} pelanggan\n`;
    await client.sendMessage(chatId, message);
  },

  async hapusPelanggan(chatId, username) {
    const success = hapusPelanggan(username);
    if (success) {
      await client.sendMessage(chatId, `Pelanggan dengan username "${username}" berhasil dihapus dari daftar.`);
    } else {
      await client.sendMessage(chatId, `Pelanggan dengan username "${username}" tidak ditemukan.`);
    }
  },

  async kirimNotifikasiManual(chatId, username) {
    const pelanggan = cariPelangganByUsername(username);
    if (!pelanggan) {
      return client.sendMessage(chatId, `Pelanggan dengan username "${username}" tidak ditemukan.`);
    }
    const historyUsers = bacaHistoryUser();
    const userHistory = buildLatestHistoryMapByName(historyUsers, true).get(String(username || "").toLowerCase());
    if (!userHistory || !userHistory.tanggalExpired) {
      return client.sendMessage(chatId, `Tidak ditemukan data expired untuk user "${username}".`);
    }
    let message = `Yth. Bapak/Ibu *${pelanggan.nama}*,\n\nPerkenankan kami menyampaikan pesan otomatis ini sebagai *Peningat Reaktivasi Akun* setiap bulan terkait status akun hotspot Anda.\n\n*Mohon diperhatikan:* Pesan ini *bukan* merupakan notifikasi jatuh tempo pembayaran, melainkan informasi status akun Anda\n\nDetail Akun Hotspot:\n*Username:* ${pelanggan.username}\n*Password:* ${pelanggan.password}\n\nTerimakasih atas perhatian Anda.`;
    try {
      await client.sendMessage(`${pelanggan.nomer}@c.us`, message);
      await client.sendMessage(chatId, `Notifikasi manual berhasil dikirim ke ${pelanggan.nama} (${pelanggan.nomer})`);
    } catch (error) {
      console.error(`[NotifManual] Gagal kirim ke ${pelanggan.nomer}:`, error);
      await client.sendMessage(chatId, `Gagal mengirim notifikasi manual ke ${pelanggan.nama} (${pelanggan.nomer}).`);
    }
  },

  async syncPelanggan(chatId) {
    await manualSyncPelanggan(chatId);
  },

  async cekPerbedaanPelanggan(chatId) {
    await cekPerbedaanPelanggan(chatId);
  },

  async perbaikiPelanggan(chatId, username, nomer) {
    await perbaikiPelanggan(chatId, username, nomer);
  },

  async kirimBroadcastInfo(chatId, pesanInfo) {
    await kirimBroadcastInfo(chatId, pesanInfo, true);
  },

  async lihatRiwayatInfo(chatId, limit = 10) {
    await lihatRiwayatInfo(chatId, limit);
  },

  async testBroadcastInfo(chatId, pesanInfo) {
    await client.sendMessage(chatId, "MENGIRIM TEST BROADCAST...\n(ini hanya contoh, tidak akan dikirim ke pelanggan)");
    const pelangganList = bacaPelanggan();
    const now = new Date().toLocaleString('id-ID');
    const contohPesan = `*INFORMASI LAYANAN EMMERIL HOTSPOT*\n\nYth. Pelanggan Emmeril Hotspot,\n\n${pesanInfo}\n\nTerima kasih atas pengertiannya.\n*Customer Service Emmeril Hotspot*`;
    await client.sendMessage(chatId, contohPesan);
    await client.sendMessage(chatId, `*CONTOH PESAN TEST*\n\nPesan akan dikirim ke ${pelangganList.length} pelanggan.\n\nGunakan \`#info <pesan>\` untuk mengirim broadcast sebenarnya.`);
  }
};

// ==================== FUNGSI TAMBAHAN (REKAP, EXCEL, DLL) ====================
const prosesRekapDariHistory = (options = {}) => {
  const { mode = 'bulanan', tanggal = null, bulan = null, tahun = null, isAutoCheck = false } = options;
  try {
    const historyUsers = bacaHistoryUser();
    const hargaProfil = bacaHargaProfil();
    const durasiProfile = bacaDurasiProfile();
    if (historyUsers.length === 0) return { error: "Tidak ada data history user." };
    const userTerpakai = historyUsers.filter((user) => user.profile && user.tanggalExpired && resolveTanggalAktifForRekap(user, durasiProfile));
    if (userTerpakai.length === 0) return { error: "Tidak ada user yang terdeteksi telah terpakai." };
    const rekapData = {};
    const nowParts = getDatePartsInTimezone(new Date(), APP_TIMEZONE);
    if (!nowParts) return { error: "Gagal membaca tanggal server untuk rekap." };
    const targetHarian = {
      hari: nowParts.hari,
      bulan: nowParts.bulan,
      tahun: nowParts.tahun
    };
    const targetBulanan = {
      bulan: bulan || nowParts.bulan,
      tahun: tahun || nowParts.tahun
    };
    const targetSpesifikTanggal = mode === 'spesifik' && tanggal
      ? (() => {
          const [hariTarget, bulanTarget, tahunTarget] = tanggal.split('-').map(Number);
          if (!isValidDateValue(hariTarget, bulanTarget, tahunTarget)) return null;
          return { hari: hariTarget, bulan: bulanTarget, tahun: tahunTarget };
        })()
      : null;

    userTerpakai.forEach(user => {
      const tanggalAktif = resolveTanggalAktifForRekap(user, durasiProfile);
      const transaksiParts = getDatePartsInTimezone(tanggalAktif, APP_TIMEZONE);
      if (!transaksiParts) return;
      const hariTransaksi = transaksiParts.hari;
      const bulanTransaksi = transaksiParts.bulan;
      const tahunTransaksi = transaksiParts.tahun;
      let key, periode, sesuai = false;
      if (mode === 'harian') {
        if (
          hariTransaksi === targetHarian.hari &&
          bulanTransaksi === targetHarian.bulan &&
          tahunTransaksi === targetHarian.tahun
        ) {
          sesuai = true;
          key = `harian-${formatPeriodeTanggal(transaksiParts)}`;
          periode = formatPeriodeTanggal(transaksiParts);
        }
      } else if (mode === 'bulanan') {
        if (bulanTransaksi === targetBulanan.bulan && tahunTransaksi === targetBulanan.tahun) {
          sesuai = true;
          key = `bulanan-${formatPeriodeBulanan({ bulan: bulanTransaksi, tahun: tahunTransaksi })}`;
          periode = formatPeriodeBulanan({ bulan: bulanTransaksi, tahun: tahunTransaksi });
        }
      } else if (mode === 'spesifik' && tanggal) {
        if (
          targetSpesifikTanggal &&
          hariTransaksi === targetSpesifikTanggal.hari &&
          bulanTransaksi === targetSpesifikTanggal.bulan &&
          tahunTransaksi === targetSpesifikTanggal.tahun
        ) {
          sesuai = true;
          key = `spesifik-${tanggal}`;
          periode = tanggal;
        }
      } else if (mode === 'spesifik' && bulan && tahun) {
        if (bulanTransaksi === bulan && tahunTransaksi === tahun) {
          sesuai = true;
          key = `spesifik-${formatPeriodeBulanan({ bulan, tahun })}`;
          periode = formatPeriodeBulanan({ bulan, tahun });
        }
      }
      if (!sesuai) return;
      if (!rekapData[key]) {
        rekapData[key] = { periode, mode, profiles: {}, totalUser: 0, totalPendapatan: 0, bulan: bulanTransaksi, tahun: tahunTransaksi };
      }
      const harga = hargaProfil[user.profile] || 0;
      if (!rekapData[key].profiles[user.profile]) {
        rekapData[key].profiles[user.profile] = { jumlah: 0, pendapatan: 0 };
      }
      rekapData[key].profiles[user.profile].jumlah++;
      rekapData[key].profiles[user.profile].pendapatan += harga;
      rekapData[key].totalUser++;
      rekapData[key].totalPendapatan += harga;
    });
    return { success: true, data: rekapData };
  } catch (error) {
    console.error('Error dalam proses rekap dari history:', error);
    return { error: "Terjadi kesalahan saat memproses rekap dari history." };
  }
};

const buatFileExcel = async (dataRekap, jenisRekap, periode) => {
  const workbook = new ExcelJS.Workbook();
  const worksheet = workbook.addWorksheet('Rekap Pendapatan');
  const headerStyle = {
    font: { bold: true, color: { argb: 'FFFFFF' } },
    fill: { type: 'pattern', pattern: 'solid', fgColor: { argb: '4472C4' } },
    alignment: { horizontal: 'center', vertical: 'middle' },
    border: { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } }
  };
  const cellStyle = {
    border: { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } },
    alignment: { vertical: 'middle' }
  };
  worksheet.mergeCells('A1:G1');
  worksheet.getCell('A1').value = `REKAP PENDAPATAN HOTSPOT - ${jenisRekap.toUpperCase()}`;
  worksheet.getCell('A1').font = { bold: true, size: 16 };
  worksheet.getCell('A1').alignment = { horizontal: 'center' };
  worksheet.mergeCells('A2:G2');
  worksheet.getCell('A2').value = `Periode: ${periode}`;
  worksheet.getCell('A2').font = { bold: true, size: 12 };
  worksheet.getCell('A2').alignment = { horizontal: 'center' };
  worksheet.mergeCells('A3:G3');
  worksheet.getCell('A3').value = `Dibuat pada: ${new Date().toLocaleString('id-ID')}`;
  worksheet.getCell('A3').font = { italic: true };
  worksheet.getCell('A3').alignment = { horizontal: 'center' };
  worksheet.getCell('A6').value = 'No';
  worksheet.getCell('B6').value = 'Tanggal Aktif';
  worksheet.getCell('C6').value = 'Profile';
  worksheet.getCell('D6').value = 'Jumlah User';
  worksheet.getCell('E6').value = 'Harga per User';
  worksheet.getCell('F6').value = 'Total Pendapatan';
  worksheet.getCell('G6').value = 'Keterangan';
  ['A6', 'B6', 'C6', 'D6', 'E6', 'F6', 'G6'].forEach(cell => {
    worksheet.getCell(cell).font = headerStyle.font;
    worksheet.getCell(cell).fill = headerStyle.fill;
    worksheet.getCell(cell).alignment = headerStyle.alignment;
    worksheet.getCell(cell).border = headerStyle.border;
  });
  let row = 7, totalSemua = 0, no = 1;
  for (const [key, data] of Object.entries(dataRekap)) {
    for (const [profile, detail] of Object.entries(data.profiles)) {
      worksheet.getCell(`A${row}`).value = no++;
      worksheet.getCell(`B${row}`).value = data.periode || `${data.bulan}/${data.tahun}`;
      worksheet.getCell(`C${row}`).value = profile;
      worksheet.getCell(`D${row}`).value = detail.jumlah;
      worksheet.getCell(`E${row}`).value = detail.pendapatan / detail.jumlah;
      worksheet.getCell(`F${row}`).value = detail.pendapatan;
      worksheet.getCell(`G${row}`).value = `User aktif pada ${data.periode || `${data.bulan}/${data.tahun}`}`;
      ['A', 'B', 'C', 'D', 'E', 'F', 'G'].forEach(col => {
        worksheet.getCell(`${col}${row}`).border = cellStyle.border;
        worksheet.getCell(`${col}${row}`).alignment = cellStyle.alignment;
      });
      worksheet.getCell(`E${row}`).numFmt = '#,##0';
      worksheet.getCell(`F${row}`).numFmt = '#,##0';
      totalSemua += detail.pendapatan;
      row++;
    }
  }
  worksheet.getCell(`A${row}`).value = 'TOTAL';
  worksheet.mergeCells(`A${row}:E${row}`);
  worksheet.getCell(`A${row}`).font = { bold: true };
  worksheet.getCell(`A${row}`).alignment = { horizontal: 'right' };
  worksheet.getCell(`F${row}`).value = totalSemua;
  worksheet.getCell(`F${row}`).font = { bold: true };
  worksheet.getCell(`F${row}`).numFmt = '#,##0';
  ['A', 'B', 'C', 'D', 'E', 'F', 'G'].forEach(col => {
    worksheet.getCell(`${col}${row}`).border = cellStyle.border;
  });
  worksheet.getColumn('A').width = 8;
  worksheet.getColumn('B').width = 18;
  worksheet.getColumn('C').width = 20;
  worksheet.getColumn('D').width = 15;
  worksheet.getColumn('E').width = 15;
  worksheet.getColumn('F').width = 18;
  worksheet.getColumn('G').width = 25;
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  const filename = `rekap_${jenisRekap}_${timestamp}.xlsx`;
  const filepath = path.join(EXCEL_FOLDER, filename);
  await workbook.xlsx.writeFile(filepath);
  return filepath;
};

const buatFileExcelGenerate = async (dataUsers, profileName, jumlahUser, prefix = "") => {
  const workbook = new ExcelJS.Workbook();
  const worksheet = workbook.addWorksheet('Generated Users');
  const headerStyle = {
    font: { bold: true, color: { argb: 'FFFFFF' } },
    fill: { type: 'pattern', pattern: 'solid', fgColor: { argb: '4472C4' } },
    alignment: { horizontal: 'center', vertical: 'middle' },
    border: { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } }
  };
  const cellStyle = {
    border: { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } },
    alignment: { vertical: 'middle' }
  };
  worksheet.mergeCells('A1:D1');
  worksheet.getCell('A1').value = `HASIL GENERATE USER HOTSPOT`;
  worksheet.getCell('A1').font = { bold: true, size: 16 };
  worksheet.getCell('A1').alignment = { horizontal: 'center' };
  worksheet.mergeCells('A2:D2');
  worksheet.getCell('A2').value = `Profile: ${profileName} | Jumlah: ${jumlahUser} user | Prefix: ${prefix || 'Tidak ada'}`;
  worksheet.getCell('A2').font = { bold: true, size: 12 };
  worksheet.getCell('A2').alignment = { horizontal: 'center' };
  worksheet.mergeCells('A3:D3');
  worksheet.getCell('A3').value = `Dibuat pada: ${new Date().toLocaleString('id-ID')}`;
  worksheet.getCell('A3').font = { italic: true };
  worksheet.getCell('A3').alignment = { horizontal: 'center' };
  worksheet.getCell('A5').value = 'No';
  worksheet.getCell('B5').value = 'Username';
  worksheet.getCell('C5').value = 'Password';
  worksheet.getCell('D5').value = 'Profile';
  ['A5', 'B5', 'C5', 'D5'].forEach(cell => {
    worksheet.getCell(cell).font = headerStyle.font;
    worksheet.getCell(cell).fill = headerStyle.fill;
    worksheet.getCell(cell).alignment = headerStyle.alignment;
    worksheet.getCell(cell).border = headerStyle.border;
  });
  let row = 6;
  dataUsers.forEach((user, index) => {
    worksheet.getCell(`A${row}`).value = index + 1;
    worksheet.getCell(`B${row}`).value = user.username;
